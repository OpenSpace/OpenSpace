{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "data": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": [
            "user_control",
            "session_recording_playback",
            "camera_path"
          ],
          "type": "string"
        }
      },
      "required": [
        "mode"
      ],
      "type": "object"
    },
    "topicId": {
      "const": "engineMode"
    },
    "topicPayload": {
      "additionalProperties": false,
      "properties": {
        "event": {
          "enum": [
            "start_subscription",
            "stop_subscription",
            "refresh"
          ],
          "type": "string"
        }
      },
      "required": [
        "event"
      ],
      "type": "object"
    }
  },
  "required": [
    "topicId",
    "topicPayload",
    "data"
  ],
  "title": "EngineModeTopic",
  "type": "object"
}
