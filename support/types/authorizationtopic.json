{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "data": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "authorized",
            "incorrectKey",
            "badRequest"
          ],
          "type": "string"
        }
      },
      "required": [
        "status"
      ],
      "type": "object"
    },
    "topicId": {
      "const": "authorize"
    },
    "topicPayload": {
      "additionalProperties": false,
      "properties": {
        "password": {
          "type": "string"
        }
      },
      "required": [
        "password"
      ],
      "type": "object"
    }
  },
  "required": [
    "topicId",
    "topicPayload",
    "data"
  ],
  "title": "AuthorizationTopic",
  "type": "object"
}
