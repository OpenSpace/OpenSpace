{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "data": {
      "additionalProperties": false,
      "properties": {
        "isPaused": {
          "type": "boolean"
        },
        "remainingTime": {
          "type": "number"
        },
        "target": {
          "type": "string"
        }
      },
      "required": [
        "target",
        "remainingTime",
        "isPaused"
      ],
      "type": "object"
    },
    "topicId": {
      "const": "cameraPath"
    },
    "topicPayload": {
      "additionalProperties": false,
      "properties": {
        "event": {
          "enum": [
            "start_subscription",
            "stop_subscription"
          ],
          "type": "string"
        }
      },
      "required": [
        "event"
      ],
      "type": "object"
    }
  },
  "required": [
    "topicId",
    "topicPayload",
    "data"
  ],
  "title": "CameraPathTopic",
  "type": "object"
}
