{
  "$defs": {
    "DownloadType": {
      "enum": [
        0,
        1,
        2,
        3
      ],
      "tsEnumNames": [
        "Started",
        "Progress",
        "Finished",
        "Failed"
      ],
      "type": "integer"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "data": {
      "additionalProperties": false,
      "properties": {
        "downloadedBytes": {
          "type": "integer"
        },
        "id": {
          "type": "string"
        },
        "totalBytes": {
          "type": "integer"
        },
        "type": {
          "$ref": "#/$defs/DownloadType"
        }
      },
      "required": [
        "type",
        "id",
        "downloadedBytes"
      ],
      "type": "object"
    },
    "topicId": {
      "const": "downloadEvent"
    },
    "topicPayload": {
      "additionalProperties": false,
      "properties": {
        "event": {
          "enum": [
            "start_subscription",
            "stop_subscription"
          ],
          "type": "string"
        }
      },
      "required": [
        "event"
      ],
      "type": "object"
    }
  },
  "required": [
    "topicId",
    "topicPayload",
    "data"
  ],
  "title": "DownloadEventTopic",
  "type": "object"
}
