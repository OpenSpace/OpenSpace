local transforms = asset.require("./transforms")



local SunLabel = {
  Identifier = "SunLabel",
  Parent = transforms.SunCenter.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Sun",
    FontSize = 70.0,
    Size = 14.17,
    MinMaxSize = { 1, 50 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "pc",
    FadeDistances = { 1.33, 15.0 },
    FadeWidths = { 1.0, 20.0 }
  },
  Tag = { "solarsystem_labels" },
  GUI = {
    Name = "Sun Label",
    Path = "/Solar System/Sun",
    Focusable = false,
    Description = "Label for the sun in our solar system"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(SunLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(SunLabel)
end)

asset.export(SunLabel)



asset.meta = {
  Name = "Sun Label",
  Description = "Label for the Sun",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
