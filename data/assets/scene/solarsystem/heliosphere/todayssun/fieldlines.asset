local transforms = asset.require("scene/solarsystem/heliosphere/transforms_heliosphere")


local transferFunctions = asset.resource({
  Type = "HttpSynchronization",
  Name = "Today's Sun Transfer Functions",
  Identifier = "todayssun_transferfunctions",
  Version = 1
})


local windSpeedPolarityColorTable = transferFunctions .. "polarity_spec.txt"
local subEarthLevelColorTable = transferFunctions .. "subearth_spec.txt"
local currentSheetColorTable = transferFunctions .. "currentsheet_spec.txt"
local opennessColorTable = transferFunctions .."openness_spec.txt"

local infoURL = "https://iswa.ccmc.gsfc.nasa.gov/api/info?dataID="
local dataURL = "https://iswa.ccmc.gsfc.nasa.gov/api/between?dataID="

local sunRadius = 695700000.0

local WSA_62_fieldlinesSCS = {
  Identifier = "WSA_62_Fieldlines_SCS_OI",
  Parent = transforms.WSAOffset60.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2025 SEP 10 16:14:00"
  },
  Transform = {
    Scale = {
      Type = "StaticScale",
      Scale = sunRadius
    },
  },
  Renderable = {
    Type = "RenderableFieldlinesSequence",
    InputFileType = "Osfls",
    LoadingType = "DynamicDownloading",
    InfoURL = infoURL,
    DataURL = dataURL,
    DataID = 2979,
    ShowAtAllTimes = false,
    ColorMethod = "By Quantity",
    ColorQuantity = 0, -- Polarity & solar wind speed
    ColorTablePaths = {
      windSpeedPolarityColorTable,
      currentSheetColorTable
    },
    ColorTableRanges = {
      { -1.0, 1.0 },
      { 0.0, 1.0 }
    }
  },
  GUI = {
    Name = "Fieldlines: Corona SCS (Out-In Tracing)",
    Path = "/Solar System/Heliosphere/WSA Coronal Model",
    Description = [[WSA 6.2 real-time output of the fieldline trace from the Schatten
      Current Sheet model (SCS) outer boundary at 21.5 Rs to the source surface at 2.5 Rs
      using GONGZ as input.]],
    Focusable = false
  }
}

local WSA_62_fieldlinesOI = {
  Identifier = "WSA_62_Fieldlines_PFSS_OI",
  Parent = transforms.WSAOffset60.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2025 SEP 10 16:14:00"
  },
  Transform = {
    Scale = {
      Type = "StaticScale",
      Scale = sunRadius
    },
  },
  Renderable = {
    Type = "RenderableFieldlinesSequence",
    InputFileType = "Osfls",
    LoadingType = "DynamicDownloading",
    InfoURL = infoURL,
    DataURL = dataURL,
    DataID = 2978,
    ShowAtAllTimes = false,
    ColorMethod = "By Quantity",
    ColorQuantity = 0, -- Polarity & solar wind speed
    ColorTablePaths = {
      windSpeedPolarityColorTable,
      currentSheetColorTable
    },
    ColorTableRanges = {
      { -1.0, 1.0 },
      { 0.0, 1.0 }
    },
  },
  GUI = {
    Name = "Fieldlines: Corona PFSS (Out-In Tracing)",
    Path = "/Solar System/Heliosphere/WSA Coronal Model",
    Description = [[WSA 6.2 real-time output of the fieldline trace from the source
      surface to the solar surface using GONGZ as input. PFSS is the Potential Field
      Source Surface model, a part of WSA.]],
    Focusable = false
  }
}

local WSA_62_fieldlinesIO = {
  Identifier = "WSA_62_Fieldlines_PFSS_IO",
  Parent = transforms.WSAOffset60.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2025 SEP 10 16:14:00"
  },
  Transform = {
    Scale = {
      Type = "StaticScale",
      Scale = sunRadius
    },
  },
  Renderable = {
    Type = "RenderableFieldlinesSequence",
    InputFileType = "Osfls",
    LoadingType = "DynamicDownloading",
    InfoURL = infoURL,
    DataURL = dataURL,
    DataID = 2977,
    ShowAtAllTimes = false,
    ColorMethod = "By Quantity",
    ColorQuantity = 0, -- Open/closed lines
    ColorTablePaths = {
      opennessColorTable
    },
    ColorTableRanges = {
      { 0.0, 2.0 }
    },
  },
  GUI = {
    Name = "Fieldlines: Corona PFSS (In-Out Tracing)",
    Path = "/Solar System/Heliosphere/WSA Coronal Model",
    Description = [[WSA 6.2 real-time output of the fieldline trace from the solar surface
      outwards using GONGZ as input. PFSS is the Potential Field Source Surface model, a
      part of WSA.]],
    Focusable = false
  }
}

local WSA_62_fieldlinesEarth = {
  Identifier = "WSA_62_Fieldlines_Earth",
  Parent = transforms.WSAOffset60.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2025 SEP 10 16:14:00"
  },
  Transform = {
    Scale = {
      Type = "StaticScale",
      Scale = sunRadius
    },
  },
  Renderable = {
    Type = "RenderableFieldlinesSequence",
    InputFileType = "Osfls",
    LoadingType = "DynamicDownloading",
    InfoURL = infoURL,
    DataURL = dataURL,
    DataID = 2980,
    ShowAtAllTimes = false,
    ColorMethod = "By Quantity",
    ColorQuantity = 0, -- Polarity
    ColorTablePaths = {
      windSpeedPolarityColorTable,
      subEarthLevelColorTable
    },
    ColorTableRanges = {
      { 0.0, 1.0 },
      { 0.0, 2.0 }
    },
  },
  GUI = {
    Name = "Fieldlines: Tracing from Earth",
    Path = "/Solar System/Heliosphere/WSA Coronal Model",
    Description = [[WSA 6.2 real-time output of the field line trace from Earth using GONGZ
      as input.]],
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(WSA_62_fieldlinesSCS)
  openspace.addSceneGraphNode(WSA_62_fieldlinesOI)
  openspace.addSceneGraphNode(WSA_62_fieldlinesIO)
  openspace.addSceneGraphNode(WSA_62_fieldlinesEarth)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(WSA_62_fieldlinesEarth)
  openspace.removeSceneGraphNode(WSA_62_fieldlinesIO)
  openspace.removeSceneGraphNode(WSA_62_fieldlinesOI)
  openspace.removeSceneGraphNode(WSA_62_fieldlinesSCS)
end)

asset.export(WSA_62_fieldlinesSCS)
asset.export(WSA_62_fieldlinesOI)
asset.export(WSA_62_fieldlinesIO)
asset.export(WSA_62_fieldlinesEarth)



asset.meta = {
  Name = "Streaming Field Line Data Dynamically",
  Version = "1.0",
  Description = [[Downloading data from the WSA 6.2 simulation model, showing the dynamic
    Sun at any point. It includes .osfls files (OpenSpace FieldLine Sequence) for field
    lines.]],
  Author = "CCMC",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
