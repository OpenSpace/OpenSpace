local sunTransforms = asset.require("scene/solarsystem/sun/transforms")
local sdoImagery = asset.require("./sdoimagery")
local stereoImagery = asset.require("./stereoimagery")
local goesImagery = asset.require("./goesimagery")
local sohoImagery = asset.require("${USER_ASSETS}/soho/sohoimagery")
local solarOrbiterImagery = asset.require("${USER_ASSETS}/solarorbiter/model.asset")

local sdoDynamicImagery = asset.require("./sdoDynamic")
local stereoDynamicImagery = asset.require("./stereoADynamic")
local goesDynamicImagery = asset.require("./goesCcor1Dynamic")
local sohoDynamicImagery = asset.require("./sohoDynamic")
local solarOrbiterDynamicImagery = asset.require("./solarOrbiterDynamic")

local SolarImageryProjection = {
  Identifier = "SunProjection_Stereo_Sdo",
  Parent = sunTransforms.SunIAU.Identifier,
  Renderable = {
    Type = "RenderableSolarImageryProjection",
    DependentNodes = {
      sdoDynamicImagery.Imagery.Identifier,
      stereoDynamicImagery.Imagery.Identifier,
      goesDynamicImagery.Imagery.Identifier,
      sohoDynamicImagery.Imagery.Identifier,
      solarOrbiterDynamicImagery.Imagery.Identifier,
    }
  },
  GUI = {
    Name = "Sun Projection",
    Path = "/Solar System/Sun/Solar Imagery",
    Description = [[Projects solar imagery from the spacecraft observatories SDO and
      STEREO-A onto the surface of the Sun. Images are mapped from their observing
      spacecraft perspectives, allowing solar features captured by different instruments
      and viewpoints to be visualized directly on the solar sphere.]]
  }
}


asset.onInitialize(function ()
  openspace.addSceneGraphNode(SolarImageryProjection)
end)

asset.onDeinitialize(function ()
  openspace.removeSceneGraphNode(SolarImageryProjection)
end)



asset.meta = {
  Name = "Solar Imagery Projection",
  Description = [[Projects solar imagery from the spacecraft observatories SDO and
    STEREO-A onto the surface of the Sun, mapping images from their observing viewpoints
    onto the solar sphere.]],
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
