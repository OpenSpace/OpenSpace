local sdo = asset.require("scene/solarsystem/missions/sdo/sdo")
local coreKernels = asset.require("spice/core")
local kernels = asset.require("scene/solarsystem/missions/sdo/kernels")
local earthTransform = asset.require("scene/solarsystem/planets/earth/transforms")

-- We use the SDO position relative to the inertial to get less wobbly image. Adding
-- the rotation further removes any small variations visible when increasing the
-- simulation time
local SdoPosition = {
  Identifier = "SDO_Position_Inertial",
  Parent = earthTransform.EarthInertial.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.SDO,
      Observer = coreKernels.ID.Earth,
      Frame = coreKernels.Frame.J2000
    },
    Rotation = {
      Type = "SpiceRotation",
      SourceFrame = coreKernels.Frame.EclipJ2000,
      DestinationFrame = coreKernels.Frame.J2000
    }
  },
  GUI = {
    Name = "SDO Position",
    Path = "/Solar System/Missions/SDO",
    Hidden = true,
    Focusable = false
  }
}

local SolarImagery = {
  Identifier = "SolarImagery_SDO_AIA193",
  Parent = SdoPosition.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = sdo.MissionBegin,
    End = sdo.MissionEnd
  },
  Renderable = {
    Type = "RenderableSolarImagery",
    ImageDirectory = openspace.absPath("${SYNC_DYNAMIC}/solarbrowsing_runtime/sdo"),
    StartInstrument = "AIA-193",

    -- DynamicDownload streams one instrument at a time for this renderable.
    -- If `Instrument` is omitted, the downloader follows the currently selected
    -- `StartInstrument` / active instrument and rebuilds itself when the user switches.
    -- Downloaded JP2 files are written into the same folder layout that the normal
    -- SolarBrowsing metadata/texture pipeline expects.
    DynamicDownload = {
      Enable = true,
      SourceId = 11,
      SpacecraftName = "SDO",
      Instrument = "AIA-193",
      CadenceSeconds = 3600.0,
      DownloadDirectory = openspace.absPath(
        "${SYNC_DYNAMIC}/solarbrowsing_runtime/sdo/AIA-193"
      ),
      PrefetchFramesBefore = 1,
      PrefetchFramesAfter = 3,
      MaxConcurrentDownloads = 2,
      SaveDownloadsOnShutdown = true,
      RetryBackoffSeconds = 30.0,
      MaxRetries = 2
    },

    DownsamplingLevel = 2,
    BlackTransparencyThreshold = 0.01,
    Contrast = 0.0,
    Gamma = 0.9
  },
  GUI = {
    Name = "SDO AIA 193 Imagery",
    Path = "/Solar System/Solar Imagery"
  }
}

asset.onInitialize(function ()
  openspace.addSceneGraphNode(SdoPosition)
  openspace.addSceneGraphNode(SolarImagery)
end)

asset.onDeinitialize(function ()
  openspace.removeSceneGraphNode(SolarImagery)
  openspace.removeSceneGraphNode(SdoPosition)
end)

asset.export("Imagery", SolarImagery)

asset.meta = {
  Name = "SDO AIA 193 Solar Imagery",
  Description = [[Runtime-streamed SDO AIA 193 imagery from Helioviewer using the
    RenderableSolarImagery DynamicDownload pipeline.]],
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
