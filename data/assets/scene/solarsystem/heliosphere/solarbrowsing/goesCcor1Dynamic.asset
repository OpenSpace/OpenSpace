local soho = asset.require("scene/solarsystem/missions/soho/soho")

local SolarImagery = {
  Identifier = "SolarImagery_GOES_CCOR1_Dynamic",
  Parent = soho.Position.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2025 MAY 22 22:00:26",
    End = "2026 APR 14 19:45:26"
  },
  Renderable = {
    Type = "RenderableSolarImagery",
    ImageDirectory = openspace.absPath("${SYNC_DYNAMIC}/solarbrowsing_runtime/goes/ccor1"),
    StartInstrument = "CCOR-1",
    TransferFunctions = {
      ["CCOR-1"] = openspace.absPath("${USER_ASSETS}/solarbrowsing/colortables/GOES-CCOR-1.txt")
    },
    DynamicDownload = {
      Enable = true,
      SpacecraftName = "GOES",
      Instrument = "CCOR-1",
      SourceId = 132,
      CadenceSeconds = 3600.0,
      PrefetchFramesBefore = 1,
      PrefetchFramesAfter = 3,
      MaxConcurrentDownloads = 2,
      SaveDownloadsOnShutdown = true,
      RetryBackoffSeconds = 30.0,
      MaxRetries = 2
    },
    DownsamplingLevel = 2,
    BlackTransparencyThreshold = 0.01,
    Contrast = 0.0,
    Gamma = 0.9
  },
  GUI = {
    Name = "GOES CCOR-1 Dynamic Imagery",
    Path = "/Solar System/Solar Imagery"
  }
}

asset.onInitialize(function ()
  openspace.addSceneGraphNode(SolarImagery)
end)

asset.onDeinitialize(function ()
  openspace.removeSceneGraphNode(SolarImagery)
end)

asset.export("Imagery", SolarImagery)

asset.meta = {
  Name = "GOES CCOR-1 Dynamic Solar Imagery",
  Description = [[Runtime-streamed GOES CCOR-1 white-light imagery from Helioviewer.]],
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
