local transforms = asset.require("scene/solarsystem/sun/transforms")



local sssb = asset.resource({
  Name = "Small SolarSystem Body Data (Other Comet)",
  Type = "HttpSynchronization",
  Identifier = "sssb_data_other_comet",
  Version = 1
})


local Object = {
  Identifier = "sssb_other_comet",
  Parent = transforms.SunEclipJ2000.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = sssb .. "sssb_data_other_comet.csv",
    Format = "SBDB",
    SegmentQuality = 4,
    Color = { 1.0, 1.0, 1.0 },
    TrailFade = 11,
    PointSizeExponent = 9.2
  },
  GUI = {
    Name = "Other Comets",
    Path = "/Solar System/Small Bodies",
    Focusable = false,
    Description = [[Comets that do not belong into any other group.]]
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(Object)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(Object)
end)

asset.export(Object)



asset.meta = {
  Name = "Other Comets",
  Description = [[RenderableSmallBody asset with data from from JPL Horizons containing the Other comet group]],
  Author = "JPL Small-Body Database hosted by California Institute of Technology",
  URL = "https://ssd.jpl.nasa.gov/sbdb_query.cgi",
  License = [[JPL-authored documents are sponsored by NASA under Contract NAS7-030010.
    All documents available from this server may be protected under the U.S. and
    Foreign Copyright Laws]]
}
