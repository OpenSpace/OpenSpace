local soho = asset.resource({
  Name = "SOHO Kernels",
  Type = "HttpSynchronization",
  Identifier = "soho_kernels",
  Version = 1
})

-- SPK kernels from:
-- https://soho.nascom.nasa.gov/sdb/soho/gen/spice/
local SohoKernels = {
  soho .. "soho_1995.bsp"
  soho .. "soho_1996.bsp"
  soho .. "soho_1997.bsp"
  soho .. "soho_1998a.bsp"
  soho .. "soho_1998b.bsp"
  soho .. "soho_1999.bsp"
  soho .. "soho_2000.bsp"
  soho .. "soho_2001.bsp"
  soho .. "soho_2002.bsp"
  soho .. "soho_2003.bsp"
  soho .. "soho_2004.bsp"
  soho .. "soho_2005.bsp"
  soho .. "soho_2006.bsp"
  soho .. "soho_2007.bsp"
  soho .. "soho_2008.bsp"
  soho .. "soho_2009.bsp"
  soho .. "soho_2010.bsp"
  soho .. "soho_2011.bsp"
  soho .. "soho_2012.bsp"
  soho .. "soho_2013.bsp"
  soho .. "soho_2014.bsp"
  soho .. "soho_2015.bsp"
  soho .. "soho_2016.bsp"
  soho .. "soho_2017.bsp"
  soho .. "soho_2018.bsp"
  soho .. "soho_2019.bsp"
  soho .. "soho_2020.bsp"
  soho .. "soho_2021.bsp"
  soho .. "soho_2022.bsp"
  soho .. "soho_2023.bsp"
  soho .. "soho_2024.bsp"
  soho .. "soho_2025.bsp"
  soho .. "soho_2026.bsp"
}

local ID = {
  SOHO = -21
}


asset.onInitialize(function()
  openspace.spice.loadKernel(SohoKernels)
end)

asset.onDeinitialize(function()
  openspace.spice.unloadKernel(SohoKernels)
end)

asset.export("ID", ID)
