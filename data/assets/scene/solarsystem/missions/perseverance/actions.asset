local Setup = {
  Identifier = "os.perseverance.Setup",
  Name = "Setup and go to Perseverance",
  Command = [[
    openspace.setPropertyValue("Scene.Mars.Renderable.Layers.HeightLayers.Mola_*.Settings.Offset", -1685.35)
    openspace.setPropertyValueSingle("Scene.Mars.Renderable.Layers.HeightLayers.HiRISE-LS-DEM.Settings.Offset", -1685.35)
    openspace.setPropertyValueSingle("Scene.Mars.Renderable.Layers.HeightLayers.MDEM200M.Settings.Offset", -1685.35)
    openspace.time.setPause(true)
    openspace.time.setTime("2021 FEB 18 20:32:16")
    openspace.setPropertyValueSingle("Scene.Mars.Renderable.Layers.HeightLayers.HiRISE-LS-DEM.Enabled", true)
    openspace.setPropertyValueSingle("Scene.Mars.Renderable.Layers.ColorLayers.HiRISE-LS.Enabled", true)
    openspace.navigation.setNavigationState({
      Anchor = "Perseverance",
      Pitch = 0.0000567457,
      Position = { 12.40506, -13.69270, -2.423553 },
      ReferenceFrame = "Root",
      Up = { 0.441211, 0.247019, 0.862737 },
      Yaw = -0.0000446853
    })
  ]],
  Documentation = "Sets time and layers for Perseverance landing",
  GuiPath = "/Missions/Perseverance",
  IsLocal = false
}

local Restore = {
  Identifier = "os.perseverance.Restore",
  Name = "Disable Perseverance landing height layer offset",
  Command = [[
    openspace.setPropertyValue("Scene.Mars.Renderable.Layers.HeightLayers.Mola_*.Settings.Offset", 0)
    openspace.setPropertyValueSingle("Scene.Mars.Renderable.Layers.HeightLayers.HiRISE-LS-DEM.Settings.Offset", 0)
    openspace.setPropertyValueSingle("Scene.Mars.Renderable.Layers.HeightLayers.MDEM200M.Settings.Offset", 0)
  ]],
  Documentation = "Undoes the layer offsets for Perseverance landing",
  GuiPath = "/Missions/Perseverance",
  IsLocal = false
}



asset.onInitialize(function()
  openspace.action.registerAction(Setup)
  openspace.action.registerAction(Restore)
end)

asset.onDeinitialize(function()
  openspace.action.removeAction(Setup)
  openspace.action.removeAction(Restore)
end)

asset.export("Setup", Setup.Identifier)
asset.export("Restore", Restore.Identifier)



asset.meta = {
  Name = "Perseverance Actions",
  Description = "Actions related to the Perseverance mission",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
