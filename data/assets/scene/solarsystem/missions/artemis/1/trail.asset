local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")
local moonAsset = asset.require("scene/solarsystem/planets/earth/moon/globe")
local kernels = asset.require("./kernels")
local coreKernels = asset.require("spice/core")



local ArtemisEarthTrail = {
  Identifier = "ArtemisEarthTrail",
  Parent = earthAsset.EarthCenter.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2022 NOV 16 08:19:00.000",
    End = "2022 DEC 11 17:20:45.065"
  },
  Renderable = {
    Type = "RenderableTrailTrajectory",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.Artemis,
      Observer = coreKernels.ID.Earth,
      Frame = coreKernels.ID.Galactic
    },
    Color = { 0.2, 0.78, 0.635 },
    Fade = 7.0,
    StartTime = "2022 NOV 16 08:19:00.000",
    EndTime = "2022 DEC 11 17:20:45.065",
    SampleInterval = 60 -- Sample rate of once per minute
  },
  GUI = {
    Name = "Artemis I Earth Trail",
    Path = "/Solar System/Missions/Artemis I/Trails",
    Focusable = false,
    Description = "Artemis I trail relative to Earth"
  }
}

local ArtemisMoonTrail = {
  Identifier = "ArtemisMoonTrail",
  Parent = moonAsset.Moon.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2022 NOV 16 08:19:00.000",
    End = "2022 DEC 11 17:20:45.065"
  },
  Renderable = {
    Type = "RenderableTrailTrajectory",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.Artemis,
      Observer = coreKernels.ID.Moon,
      Frame = coreKernels.Frame.Moon
    },
    Color = { 0.78, 0.43, 0.20 },
    Fade = 7.0,
    StartTime = "2022 NOV 16 08:19:00.000",
    EndTime = "2022 DEC 11 17:20:45.065",
    SampleInterval = 60 -- Sample rate of once per minute
  },
  GUI = {
    Name = "Artemis I Moon Trail",
    Path = "/Solar System/Missions/Artemis I/Trails",
    Focusable = false,
    Description = "Artemis I trail relative to the Moon"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(ArtemisEarthTrail)
  openspace.addSceneGraphNode(ArtemisMoonTrail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(ArtemisMoonTrail)
  openspace.removeSceneGraphNode(ArtemisEarthTrail)
end)

asset.export(ArtemisEarthTrail)
asset.export(ArtemisMoonTrail)



asset.meta = {
  Name = "Artemis I Trails",
  Description = "Trail of Artemis I in respect to Earth and the Moon",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
