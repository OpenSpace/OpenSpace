local sunAsset = asset.require("scene/solarsystem/sun/transforms")
local transforms = asset.require("./transforms")



local models = asset.resource({
  Name = "Artemis I Models",
  Type = "HttpSynchronization",
  Identifier = "artemis_1_models",
  Version = 1
})


local ArtemisModel = {
  Identifier = "ArtemisModel",
  Parent = transforms.ArtemisPosition.Identifier,
  ApproachFactor = 2700,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2022 NOV 16 08:19:00.000",
    End = "2022 DEC 11 17:20:45.065"
  },
  Transform = {
    Rotation = {
      Type = "FixedRotation",
      Attached = "ArtemisModel",
      XAxis = { 1.0, 0.0, 0.0 },
      XAxisOrthogonal = true,
      YAxis = sunAsset.SunCenter.Identifier,
      YAxisInvert = true
    }
  },
  Renderable = {
    Type = "RenderableModel",
    GeometryFile = models .. "artemis.glb",
    LightSources = {
      sunAsset.LightSource
    },
    AmbientIntensity = 0.05,
    EnableFaceCulling = false
  },
  GUI = {
    Name = "Orion Model (Artemis I)",
    Path = "/Solar System/Missions/Artemis I",
    Description = "Model of the Orion capsule for the Artemis I mission"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(ArtemisModel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(ArtemisModel)
end)

asset.export(ArtemisModel)



asset.meta = {
  Name = "Artemis I Model",
  Description = "Orion capsule model for the Artemis I mission",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
