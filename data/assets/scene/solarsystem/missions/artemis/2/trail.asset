local earthTransforms = asset.require("scene/solarsystem/planets/earth/transforms")
local moon = asset.require("scene/solarsystem/planets/earth/moon/globe")
local kernels = asset.require("./kernels")
local coreKernels = asset.require("spice/core")



local Artemis2EarthTrail = {
  Identifier = "Artemis2EarthTrail",
  Parent = earthTransforms.EarthCenter.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2026 APR 02 01:49:00.000",
    End = "2026 APR 10 23:54:13.000"
  },
  Renderable = {
    Type = "RenderableTrailTrajectory",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.Artemis2,
      Observer = coreKernels.ID.Earth,
      Frame = coreKernels.Frame.Galactic
    },
    Color = { 0.6823, 0.7803, 0.2 },
    Fade = 7.0,
    StartTime = "2026 APR 02 01:49:00.000",
    EndTime = "2026 APR 10 23:54:13.000",
    SampleInterval = 60 -- Sample rate of once per minute
  },
  GUI = {
    Name = "Artemis II Earth Trail",
    Path = "/Solar System/Missions/Artemis II/Trails",
    Focusable = false,
    Description = "Artemis II trail relative to Earth"
  }
}

local Artemis2MoonTrail = {
  Identifier = "Artemis2MoonTrail",
  Parent = moon.Moon.Identifier,
  TimeFrame = {
    Type = "TimeFrameInterval",
    Start = "2026 APR 02 01:49:00.000",
    End = "2026 APR 10 23:54:13.000"
  },
  Renderable = {
    Type = "RenderableTrailTrajectory",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.Artemis2,
      Observer = coreKernels.ID.Moon,
      Frame = coreKernels.Frame.Moon
    },
    Color = { 0.596, 0.2, 0.7803 },
    Fade = 7.0,
    StartTime = "2026 APR 02 01:49:00.000",
    EndTime = "2026 APR 10 23:54:13.000",
    SampleInterval = 60 -- Sample rate of once per minute
  },
  GUI = {
    Name = "Artemis II Moon Trail",
    Path = "/Solar System/Missions/Artemis II/Trails",
    Focusable = false,
    Description = "Artemis II trail relative to the Moon."
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(Artemis2EarthTrail)
  openspace.addSceneGraphNode(Artemis2MoonTrail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(Artemis2MoonTrail)
  openspace.removeSceneGraphNode(Artemis2EarthTrail)
end)

asset.export(Artemis2EarthTrail)
asset.export(Artemis2MoonTrail)



asset.meta = {
  Name = "Artemis II Trails",
  Description = "Trail of Artemis II in respect to Earth and the Moon.",
  Author = "Dan Tell, Tau Immersive",
  URL = "http://tauimmersive.com",
  License = "MIT license"
}
