local mercuryAsset = asset.require("scene/solarsystem/planets/mercury/mercury")
local messengerAsset = asset.require("./messenger")



local Distance = {
  Type = "DashboardItemDistance",
  Identifier = "MessengerDistance",
  GuiName = "Messenger - Mercury Distance",
  SourceType = "Node",
  SourceNodeIdentifier = messengerAsset.Messenger.Identifier,
  DestinationType = "Node",
  DestinationNodeIdentifier = mercuryAsset.Mercury.Identifier
}


asset.onInitialize(function()
  openspace.dashboard.addDashboardItem(Distance)
end)

asset.onDeinitialize(function()
  openspace.dashboard.removeDashboardItem(Distance)
end)
