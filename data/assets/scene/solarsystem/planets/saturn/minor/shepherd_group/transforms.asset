local transforms = asset.require("scene/solarsystem/planets/saturn/transforms")
local kernels415 = asset.require("scene/solarsystem/planets/saturn/kernels415")
local coreKernels = asset.require("spice/core")



local syncedKernels = asset.resource({
  Name = "Saturn Shepherd Moons Spice Kernels",
  Type = "HttpSynchronization",
  Identifier = "saturn_shepherd_kernels",
  Version = 1
})


local kernels = {
  syncedKernels .. "sat415.bsp",
  syncedKernels .. "sat393_daphnis.bsp"
}

local PrometheusPosition = {
  Identifier = "PrometheusPosition",
  Parent = transforms.SaturnBarycenter.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels415.ID.Prometheus,
      Observer = coreKernels.ID.SaturnBarycenter
    }
  },
  GUI = {
    Name = "Prometheus Position",
    Path = "/Solar System/Planets/Saturn/Minor Moons/Shepherd Moons/Prometheus",
    Focusable = false,
    Hidden = true
  }
}

local PandoraPosition = {
  Identifier = "PandoraPosition",
  Parent = transforms.SaturnBarycenter.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels415.ID.Pandora,
      Observer = coreKernels.ID.SaturnBarycenter
    }
  },
  GUI = {
    Name = "Pandora Position",
    Path = "/Solar System/Planets/Saturn/Minor Moons/Shepherd Moons/Pandora",
    Focusable = false,
    Hidden = true
  }
}

