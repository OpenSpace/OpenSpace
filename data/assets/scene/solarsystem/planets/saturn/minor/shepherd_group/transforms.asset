  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels415.ID.Atlas,
      Observer = coreKernels.ID.SaturnBarycenter
    }
  },
  GUI = {
    Name = "Atlas Position",
    Path = "/Solar System/Planets/Saturn/Minor Moons/Shepherd Moons/Atlas",
    Focusable = false,
    Hidden = true
  }
}

local JanusPosition = {
