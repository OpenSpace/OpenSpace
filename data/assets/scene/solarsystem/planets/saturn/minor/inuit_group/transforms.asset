local transforms = asset.require("scene/solarsystem/planets/saturn/transforms")
local kernels454 = asset.require("scene/solarsystem/planets/saturn/kernels454")
local coreKernels = asset.require("spice/core")



local KiviuqPosition = {
  Identifier = "KiviuqPosition",
  Parent = transforms.SaturnBarycenter.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels454.ID.Kiviuq,
      Observer = coreKernels.ID.SaturnBarycenter
    }
  },
  GUI = {
    Name = "Kiviuq Position",
    Path = "/Solar System/Planets/Saturn/Minor Moons/Inuit Group/Kiviuq",
    Focusable = false,
    Hidden = true
  }
}

