asset.onInitialize(function()
  openspace.addSceneGraphNode(KiviuqPosition)
  openspace.addSceneGraphNode(IjiraqPosition)
  openspace.addSceneGraphNode(PaaliaqPosition)
  openspace.addSceneGraphNode(SiarnaqPosition)
  openspace.addSceneGraphNode(TarqeqPosition)
  openspace.addSceneGraphNode(S2004S29Position)
  openspace.addSceneGraphNode(S2004S31Position)
  openspace.addSceneGraphNode(S2019S01Position)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(S2019S01Position)
  openspace.removeSceneGraphNode(S2004S31Position)
  openspace.removeSceneGraphNode(S2004S29Position)
  openspace.removeSceneGraphNode(TarqeqPosition)
  openspace.removeSceneGraphNode(SiarnaqPosition)
  openspace.removeSceneGraphNode(PaaliaqPosition)
  openspace.removeSceneGraphNode(IjiraqPosition)
  openspace.removeSceneGraphNode(KiviuqPosition)
end)

asset.export(KiviuqPosition)
asset.export(IjiraqPosition)
asset.export(PaaliaqPosition)
asset.export(SiarnaqPosition)
asset.export(TarqeqPosition)
asset.export(S2004S29Position)
asset.export(S2004S31Position)
asset.export(S2019S01Position)



asset.meta = {
  Name = "Saturn Inuit Group Moons Positions",
  Description = [[Asset containing positions for Saturn's Inuit Group moons.]],
