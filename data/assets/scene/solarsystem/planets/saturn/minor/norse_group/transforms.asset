asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(S2004S39Position)
  openspace.removeSceneGraphNode(S2004S37Position)
  openspace.removeSceneGraphNode(S2004S36Position)
  openspace.removeSceneGraphNode(S2004S21Position)
  openspace.removeSceneGraphNode(S2004S28Position)
  openspace.removeSceneGraphNode(GeirrodPosition)
  openspace.removeSceneGraphNode(AlvaldiPosition)
  openspace.removeSceneGraphNode(S2004S34Position)
  openspace.removeSceneGraphNode(ThiazziPosition)
  openspace.removeSceneGraphNode(GunnlodPosition)
  openspace.removeSceneGraphNode(BeliPosition)
  openspace.removeSceneGraphNode(EggtherPosition)
  openspace.removeSceneGraphNode(S2004S26Position)
  openspace.removeSceneGraphNode(GerdPosition)
  openspace.removeSceneGraphNode(SkrymirPosition)
  openspace.removeSceneGraphNode(AngrbodaPosition)
  openspace.removeSceneGraphNode(GridrPosition)
