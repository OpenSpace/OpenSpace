  openspace.addSceneGraphNode(LogePosition)
  openspace.addSceneGraphNode(FornjotPosition)
  openspace.addSceneGraphNode(GridrPosition)
  openspace.addSceneGraphNode(AngrbodaPosition)
  openspace.addSceneGraphNode(SkrymirPosition)
  openspace.addSceneGraphNode(GerdPosition)
  openspace.addSceneGraphNode(S2004S26Position)
  openspace.addSceneGraphNode(EggtherPosition)
  openspace.addSceneGraphNode(BeliPosition)
  openspace.addSceneGraphNode(GunnlodPosition)
  openspace.addSceneGraphNode(ThiazziPosition)
  openspace.addSceneGraphNode(S2004S34Position)
  openspace.addSceneGraphNode(AlvaldiPosition)
  openspace.addSceneGraphNode(GeirrodPosition)
  openspace.addSceneGraphNode(S2004S28Position)
  openspace.addSceneGraphNode(S2004S21Position)
