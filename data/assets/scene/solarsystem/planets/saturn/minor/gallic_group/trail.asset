asset.onInitialize(function()
  openspace.addSceneGraphNode(AlbiorixTrail)
  openspace.addSceneGraphNode(BebhionnTrail)
  openspace.addSceneGraphNode(ErriapusTrail)
  openspace.addSceneGraphNode(TarvosTrail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TarvosTrail)
  openspace.removeSceneGraphNode(ErriapusTrail)
  openspace.removeSceneGraphNode(BebhionnTrail)
  openspace.removeSceneGraphNode(AlbiorixTrail)
end)

asset.export(AlbiorixTrail)
asset.export(BebhionnTrail)
asset.export(ErriapusTrail)
asset.export(TarvosTrail)



asset.meta = {
  Name = "Saturn Gallic Group Moons Trails",
  Description = [[Aasset containing trails for Saturn's Gallic Group moons.]],
