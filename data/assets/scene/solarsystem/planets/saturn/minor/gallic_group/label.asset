asset.onInitialize(function()
  openspace.addSceneGraphNode(AlbiorixLabel)
  openspace.addSceneGraphNode(BebhionnLabel)
  openspace.addSceneGraphNode(ErriapusLabel)
  openspace.addSceneGraphNode(TarvosLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TarvosLabel)
  openspace.removeSceneGraphNode(ErriapusLabel)
  openspace.removeSceneGraphNode(BebhionnLabel)
  openspace.removeSceneGraphNode(AlbiorixLabel)
end)

asset.export(AlbiorixLabel)
asset.export(BebhionnLabel)
asset.export(ErriapusLabel)
asset.export(TarvosLabel)



asset.meta = {
  Name = "Saturn Gallic Group Moons Labels",
