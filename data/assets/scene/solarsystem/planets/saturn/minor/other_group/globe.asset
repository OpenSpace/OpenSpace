asset.onInitialize(function()
  openspace.addSceneGraphNode(Aegaeon)
  openspace.addSceneGraphNode(Methone)
  openspace.addSceneGraphNode(Anthe)
  openspace.addSceneGraphNode(Pallene)
  openspace.addSceneGraphNode(Telesto)
  openspace.addSceneGraphNode(Calypso)
  openspace.addSceneGraphNode(Helene)
  openspace.addSceneGraphNode(Polydeuces)
  openspace.addSceneGraphNode(S2004S24)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(Aegaeon)
  openspace.removeSceneGraphNode(Methone)
  openspace.removeSceneGraphNode(Anthe)
  openspace.removeSceneGraphNode(Pallene)
  openspace.removeSceneGraphNode(Telesto)
  openspace.removeSceneGraphNode(Calypso)
  openspace.removeSceneGraphNode(Helene)
  openspace.removeSceneGraphNode(Polydeuces)
  openspace.removeSceneGraphNode(S2004S24)
end)

asset.export(Aegaeon)
asset.export(Methone)
asset.export(Anthe)
asset.export(Pallene)
asset.export(Telesto)
asset.export(Calypso)
asset.export(Helene)
asset.export(Polydeuces)
asset.export(S2004S24)



asset.meta = {
  Name = "Saturn Other Group Moons",
  Description = [[Procedural Globe asset containing Saturn's Other Group moons: Aegaeon,
    Methone, Anthe, Pallene, Telesto, Calypso, Helene, Polydeuces. Blank globes and SPICE
    trails are generated for each moon]],
