local transforms = asset.require("./transforms")



local AegaeonLabel = {
  Identifier = "AegaeonLabel",
  Parent = transforms.AegaeonPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Aegaeon",
    FontSize = 70.0,
    Size = 5.5,
    MinMaxSize = { 1, 20 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Mm",
    FadeDistances = { 250.0, 1500.0 },
    FadeWidths = { 100.0, 1500.0 }
  },
  Tag = {
    "solarsystem_labels",
    "moon_labels",
    "minor_moon_labels",
    "minor_moon_labels_saturn",
    "minor_moon_labels_other"
  },
  GUI = {
    Name = "Aegaeon Label",
    Path = "/Solar System/Planets/Saturn/Minor Moons/Other Group/Aegaeon",
