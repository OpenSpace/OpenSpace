asset.onInitialize(function()
  openspace.addSceneGraphNode(AegaeonLabel)
  openspace.addSceneGraphNode(MethoneLabel)
  openspace.addSceneGraphNode(AntheLabel)
  openspace.addSceneGraphNode(PalleneLabel)
  openspace.addSceneGraphNode(TelestoLabel)
  openspace.addSceneGraphNode(CalypsoLabel)
  openspace.addSceneGraphNode(HeleneLabel)
  openspace.addSceneGraphNode(PolydeucesLabel)
  openspace.addSceneGraphNode(S2004S24Label)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(AegaeonLabel)
  openspace.removeSceneGraphNode(MethoneLabel)
  openspace.removeSceneGraphNode(AntheLabel)
  openspace.removeSceneGraphNode(PalleneLabel)
  openspace.removeSceneGraphNode(TelestoLabel)
  openspace.removeSceneGraphNode(CalypsoLabel)
  openspace.removeSceneGraphNode(HeleneLabel)
  openspace.removeSceneGraphNode(PolydeucesLabel)
  openspace.removeSceneGraphNode(S2004S24Label)
end)

asset.export(AegaeonLabel)
asset.export(MethoneLabel)
asset.export(AntheLabel)
asset.export(PalleneLabel)
asset.export(TelestoLabel)
asset.export(CalypsoLabel)
asset.export(HeleneLabel)
asset.export(PolydeucesLabel)
asset.export(S2004S24Label)



asset.meta = {
  Name = "Saturn Other Group Moons Labels",
  Description = [[Asset containing labels for Saturn's Other Group moons.]],
