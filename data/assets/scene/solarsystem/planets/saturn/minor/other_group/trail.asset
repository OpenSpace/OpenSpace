asset.onInitialize(function()
  openspace.addSceneGraphNode(AegaeonTrail)
  openspace.addSceneGraphNode(MethoneTrail)
  openspace.addSceneGraphNode(AntheTrail)
  openspace.addSceneGraphNode(PalleneTrail)
  openspace.addSceneGraphNode(TelestoTrail)
  openspace.addSceneGraphNode(CalypsoTrail)
  openspace.addSceneGraphNode(HeleneTrail)
  openspace.addSceneGraphNode(PolydeucesTrail)
  openspace.addSceneGraphNode(S2004S24Trail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(AegaeonTrail)
  openspace.removeSceneGraphNode(MethoneTrail)
  openspace.removeSceneGraphNode(AntheTrail)
  openspace.removeSceneGraphNode(PalleneTrail)
  openspace.removeSceneGraphNode(TelestoTrail)
  openspace.removeSceneGraphNode(CalypsoTrail)
  openspace.removeSceneGraphNode(HeleneTrail)
  openspace.removeSceneGraphNode(PolydeucesTrail)
  openspace.removeSceneGraphNode(S2004S24Trail)
end)

asset.export(AegaeonTrail)
asset.export(MethoneTrail)
asset.export(AntheTrail)
asset.export(PalleneTrail)
asset.export(TelestoTrail)
asset.export(CalypsoTrail)
asset.export(HeleneTrail)
asset.export(PolydeucesTrail)
asset.export(S2004S24Trail)



asset.meta = {
