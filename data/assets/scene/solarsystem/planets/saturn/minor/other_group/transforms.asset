local transforms = asset.require("scene/solarsystem/planets/saturn/transforms")
local kernels = asset.require("scene/solarsystem/planets/saturn/kernels")
local kernels415 = asset.require("scene/solarsystem/planets/saturn/kernels415")
local kernels454 = asset.require("scene/solarsystem/planets/saturn/kernels454")
local coreKernels = asset.require("spice/core")



local AegaeonPosition = {
  Identifier = "AegaeonPosition",
  Parent = transforms.SaturnBarycenter.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels415.ID.Aegaeon,
      Observer = coreKernels.ID.SaturnBarycenter
    }
  },
  GUI = {
    Name = "Aegaeon Position",
    Path = "/Solar System/Planets/Saturn/Minor Moons/Other Group/Aegaeon",
    Focusable = false,
    Hidden = true
  }
}

