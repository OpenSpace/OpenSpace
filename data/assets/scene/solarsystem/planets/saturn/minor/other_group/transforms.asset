asset.onInitialize(function()
  openspace.addSceneGraphNode(AegaeonPosition)
  openspace.addSceneGraphNode(MethonePosition)
  openspace.addSceneGraphNode(AnthePosition)
  openspace.addSceneGraphNode(PallenePosition)
  openspace.addSceneGraphNode(TelestoPosition)
  openspace.addSceneGraphNode(CalypsoPosition)
  openspace.addSceneGraphNode(HelenePosition)
  openspace.addSceneGraphNode(PolydeucesPosition)
  openspace.addSceneGraphNode(S2004S24Position)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(AegaeonPosition)
  openspace.removeSceneGraphNode(MethonePosition)
  openspace.removeSceneGraphNode(AnthePosition)
  openspace.removeSceneGraphNode(PallenePosition)
  openspace.removeSceneGraphNode(TelestoPosition)
  openspace.removeSceneGraphNode(CalypsoPosition)
  openspace.removeSceneGraphNode(HelenePosition)
  openspace.removeSceneGraphNode(PolydeucesPosition)
  openspace.removeSceneGraphNode(S2004S24Position)
end)

asset.export(AegaeonPosition)
asset.export(MethonePosition)
asset.export(AnthePosition)
asset.export(PallenePosition)
asset.export(TelestoPosition)
asset.export(CalypsoPosition)
asset.export(HelenePosition)
asset.export(PolydeucesPosition)
asset.export(S2004S24Position)



asset.meta = {
  Name = "Saturn Other Group Moons Positions",
  Description = [[Asset containing positions for Saturn's Other Group moons.]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
