local rheaAsset = asset.require("scene/solarsystem/planets/saturn/rhea/globe")



local texturesPath = asset.resource({
  Name = "Rhea textures",
  Type = "HttpSynchronization",
  Identifier = "rhea_textures",
  Version = 1
})


local Layer = {
  Identifier = "Texture",
  FilePath = texturesPath .. "rhea.jpg",
  Enabled = asset.enabled,
  ZIndex = 5
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(rheaAsset.Rhea.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(rheaAsset.Rhea.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Rhea Texutre",
  Description = "Default jpg texture for Rhea",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
