local transforms = asset.require("./transforms")



local RheaLabel = {
  Identifier = "RheaLabel",
  Parent = transforms.RheaPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Rhea",
    FontSize = 70.0,
    Size = 6.0,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Normal",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 0.3, 10.0 },
    FadeWidths = { 0.15, 10.0 }
  },
  Tag = { "solarsystem_labels", "moon_labels", "major_moon_labels", "moon_major_saturn" },
  GUI = {
    Name = "Rhea Label",
    Path = "/Solar System/Planets/Saturn/Major Moons/Rhea",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(RheaLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(RheaLabel)
end)

asset.export(RheaLabel)



asset.meta = {
  Name = "Rhea Label",
  Description = "Label for Rhea",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
