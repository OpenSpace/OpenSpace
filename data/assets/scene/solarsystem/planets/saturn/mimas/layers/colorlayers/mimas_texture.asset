local mimasAsset = asset.require("scene/solarsystem/planets/saturn/mimas/globe")



local texturesPath = asset.resource({
  Name = "Mimas textures",
  Type = "HttpSynchronization",
  Identifier = "mimas_textures",
  Version = 1
})


local Layer = {
  Identifier = "Texture",
  FilePath = texturesPath .. "mimas.jpg",
  Enabled = asset.enabled,
  ZIndex = 5
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(mimasAsset.Mimas.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(mimasAsset.Mimas.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Mimas Texutre",
  Description = "Default jpg texture for Mimas",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
