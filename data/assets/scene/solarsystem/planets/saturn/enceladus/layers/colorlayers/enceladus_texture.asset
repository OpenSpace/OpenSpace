local enceladusAsset = asset.require("scene/solarsystem/planets/saturn/enceladus/globe")



local texturesPath = asset.resource({
  Name = "Enceladus textures",
  Type = "HttpSynchronization",
  Identifier = "enceladus_textures",
  Version = 1
})


local Layer = {
  Identifier = "Texture",
  FilePath = texturesPath .. "enceladus.jpg",
  Enabled = asset.enabled,
  ZIndex = 5
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(enceladusAsset.Enceladus.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(enceladusAsset.Enceladus.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Enceladus Texture",
  Description = "Default jpg texture for Enceladus",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
