local iapetusAsset = asset.require("scene/solarsystem/planets/saturn/iapetus/globe")



local texturesPath = asset.resource({
  Name = "Iapetus textures",
  Type = "HttpSynchronization",
  Identifier = "iapetus_textures",
  Version = 1
})


local layer = {
  Identifier = "Texture",
  FilePath = texturesPath .. "iapetus.jpg",
  Enabled = asset.enabled,
  ZIndex = 5
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(iapetusAsset.Iapetus.Identifier, "ColorLayers", layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(iapetusAsset.Iapetus.Identifier, "ColorLayers", layer)
end)

asset.export("layer", layer)



asset.meta = {
  Name = "Iapetus Texutre",
  Description = "Default jpg texture for Iapetus",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
