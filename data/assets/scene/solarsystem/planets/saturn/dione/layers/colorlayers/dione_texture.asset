local dioneAsset = asset.require("scene/solarsystem/planets/saturn/dione/globe")



local texturesPath = asset.resource({
  Name = "Dione textures",
  Type = "HttpSynchronization",
  Identifier = "dione_textures",
  Version = 1
})


local Layer = {
  Identifier = "Texture",
  FilePath = texturesPath .. "dione.jpg",
  Enabled = asset.enabled,
  ZIndex = 5
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(dioneAsset.Dione.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(dioneAsset.Dione.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Dione Texutre",
  Description = "Default jpg texture for Dione",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
