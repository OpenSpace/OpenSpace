local transforms = asset.require("./transforms")
local coreKernels = asset.require("spice/core")



local MercuryLabel = {
  Identifier = "MercuryLabel",
  Parent = transforms.MercuryBarycenter.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Mercury",
    FontSize = 70.0,
    Size = 8.5,
    MinMaxSize = { 1, 40 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "au",
    FadeDistances = { 0.75, 20.0 },
    FadeWidths = { 1.0, 30.0 }
  },
  Tag = { "solarsystem_labels" },
  GUI = {
    Name = "Mercury Label",
    Path = "/Solar System/Planets/Mercury",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(MercuryLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(MercuryLabel)
end)

asset.export(MercuryLabel)



asset.meta = {
  Name = "Mercury Label",
  Description = "Label for Mercury",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
