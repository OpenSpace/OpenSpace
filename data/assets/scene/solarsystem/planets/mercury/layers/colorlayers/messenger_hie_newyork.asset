local mercuryAsset = asset.require("scene/solarsystem/planets/mercury/globe")



local Layer = {
  Identifier = "Messenger_HIE_NewYork",
  Name = "Messenger HIE [New York]",
  Enabled = asset.enabled,
  ZIndex = 10,
  FilePath = asset.resource("messenger_hie_newyork.wms")
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(mercuryAsset.Mercury.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(mercuryAsset.Mercury.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Messenger HIE [New York]",
  Description = [[Mercury HIE layer for Mercury globe. This map is hosted on the OpenSpace
    server in New York]],
  Author = "USGS",
  URL = "",
  License = "NASA/PDS"
}

