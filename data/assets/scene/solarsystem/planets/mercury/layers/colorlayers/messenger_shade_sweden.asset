local mercuryAsset = asset.require("scene/solarsystem/planets/mercury/globe")



local Layer = {
  Identifier = "Messenger_SHADE_Sweden",
  Name = "Messenger SHADE [Sweden]",
  Enabled = asset.enabled,
  ZIndex = 100,
  FilePath = asset.resource("messenger_shade_sweden.wms"),
  Settings = {
    Gamma = 1.33,
    Multiplier = 1.15
  },
  BlendMode = "Multiply"
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(mercuryAsset.Mercury.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(mercuryAsset.Mercury.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Messenger SHADE [Sweden]",
  Description = [[Mercury SHADE layer for Mercury globe. This map is hosted on the
    OpenSpace server in Sweden]],
  Author = "USGS",
  URL = "https://astrogeology.usgs.gov/search/map/Mercury/Topography/MESSENGER/Mercury_Messenger_USGS_ClrShade_Global_2km",
  License = "NASA/PDS"
}
