local mercuryAsset = asset.require("scene/solarsystem/planets/mercury/globe")



local texturesPath = asset.resource({
  Name = "Mercury Textures",
  Type = "HttpSynchronization",
  Identifier = "mercury_abundance_textures",
  Version = 1
})


local Layer = {
  Name = "Calcium Abundance",
  Identifier = "casimap_02122015",
  Enabled = asset.enabled,
  ZIndex = 100,
  FilePath = texturesPath .. "casimap_02122015.png",
  BlendMode = "Multiply"
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(mercuryAsset.Mercury.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(mercuryAsset.Mercury.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Mercury Calcium Abundance",
  Description = "Calcium Abundance layer for Mercury globe",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
