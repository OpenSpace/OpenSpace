local globe = asset.require("./globe")



local CallistoLabel = {
  Identifier = "CallistoLabel",
  Parent = globe.Callisto.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = false,
    Text = "Callisto",
    FontSize = 70.0,
    Size = 6.0,
    MinMaxSize = { 1, 40 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 1.0, 10.0 },
    FadeWidths = { 0.5, 10.0 }
  },
  Tag = { "solarsystem_labels", "moon_labels", "major_moon_labels" },
  GUI = {
    Name = "Callisto Label",
    Path = "/Solar System/Planets/Jupiter/Major Moons/Callisto",
    Focusable = false,
    Description = "Label for Jupiter's moon Callisto"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(CallistoLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(CallistoLabel)
end)

asset.export(CallistoLabel)



asset.meta = {
  Name = "Callisto Label",
  Description = "Label for Callisto",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
