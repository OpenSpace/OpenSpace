local ganymedeAsset = asset.require("scene/solarsystem/planets/jupiter/ganymede/ganymede")



local texturesPath = asset.resource({
  Name = "Ganymede Textures",
  Type = "HttpSynchronization",
  Identifier = "ganymede_textures",
  Version = 1
})


local Layer = {
  Identifier = "Texture",
  FilePath = texturesPath .. "ganymede.jpg",
  Enabled = asset.enabled,
  ZIndex = 5
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(ganymedeAsset.Ganymede.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(ganymedeAsset.Ganymede.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Ganymede Texutre",
  Description = "Default jpg texture for Ganymede",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
