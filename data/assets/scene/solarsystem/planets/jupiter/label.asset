local transforms = asset.require("./transforms")



local JupiterLabel = {
  Identifier = "JupiterLabel",
  Parent = transforms.JupiterBarycenter.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Text = "Jupiter",
    FontSize = 70.0,
    Size = 8.75,
    MinMaxSize = { 1, 50 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "au",
    FadeDistances = { 3.0, 40.0 },
    FadeWidths = { 1.0, 60.0 }
  },
  Tag = { "solarsystem_labels" },
  GUI = {
    Name = "Jupiter Label",
    Path = "/Solar System/Planets/Jupiter",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(JupiterLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(JupiterLabel)
end)

asset.export(JupiterLabel)



asset.meta = {
  Name = "Jupiter",
  Description = "The label for Jupiter",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
