local ioAsset = asset.require("scene/solarsystem/planets/jupiter/io/globe")



local texturesPath = asset.resource({
  Name = "Io Textures",
  Type = "HttpSynchronization",
  Identifier = "io_textures",
  Version = 1
})


local Layer = {
  Identifier = "Texture",
  FilePath = texturesPath .. "io.jpg",
  Enabled = asset.enabled,
  ZIndex = 5
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(ioAsset.Io.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(ioAsset.Io.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Io Texutre",
  Description = "Default jpg texture for Io",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
