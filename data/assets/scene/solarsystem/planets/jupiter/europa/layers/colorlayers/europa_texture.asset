local europaAsset = asset.require("scene/solarsystem/planets/jupiter/europa/europa")



local texturesPath = asset.resource({
  Name = "Europa Textures",
  Type = "HttpSynchronization",
  Identifier = "europa_textures",
  Version = 2
})


local Layer = {
  Identifier = "Texture",
  FilePath = texturesPath .. "europa_os.tif",
  Enabled = asset.enabled,
  ZIndex = 5
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(europaAsset.Europa.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(europaAsset.Europa.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Europa Texutre",
  Description = "Default texture for Europa",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
