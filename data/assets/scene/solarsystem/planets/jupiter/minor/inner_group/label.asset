local transforms = asset.require("./transforms")



local MetisLabel = {
  Identifier = "MetisLabel",
  Parent = transforms.MetisPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Metis",
    FontSize = 50.0,
    Size = 5.6,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 0.1, 3.0 },
    FadeWidths = { 0.1, 3.0 }
  },
  Tag = {
    "solarsystem_labels",
    "moon_labels",
    "minor_moon_labels",
    "minor_moon_labels_jupiter",
    "minor_moon_labels_inner"
  },
  GUI = {
    Name = "Metis Label",
    Path = "/Solar System/Planets/Jupiter/Minor Moons/Inner Group/Metis",
    Focusable = false,
    Description = "Label for Jupiter's moon Metis (inner group)"
  }
}

