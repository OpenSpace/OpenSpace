local transforms = asset.require("scene/solarsystem/planets/jupiter/transforms")
local kernels347 = asset.require("scene/solarsystem/planets/jupiter/kernels347")
local coreKernels = asset.require("spice/core")



local CarpoTrail = {
  Identifier = "CarpoTrail",
  Parent = transforms.JupiterBarycenter.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels347.ID.Carpo,
      Observer = coreKernels.ID.JupiterBarycenter
    },
    Color = { 0.4, 0.3, 0.01 },
    Period = 458.62,
    Resolution = 1000
  },
  Tag = {
    "moonTrail_solarSystem",
    "moonTrail_giants",
    "moonTrail_jupiter",
    "moonTrail_carpo",
    "moonTrail_minor",
    "moonTrail_minor_jupiter"
  },
  GUI = {
    Name = "Carpo Trail",
    Path = "/Solar System/Planets/Jupiter/Minor Moons/Carpo Group/Carpo",
    Focusable = false
  }
}

local S2018J4Trail = {
  Identifier = "S2018J4Trail",
  Parent = transforms.JupiterBarycenter.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels347.ID.S2018J4,
      Observer = coreKernels.ID.JupiterBarycenter
    },
    Color = { 0.4, 0.3, 0.01 },
    Period = 458.62,
    Resolution = 1000
  },
  Tag = {
    "moonTrail_solarSystem",
    "moonTrail_giants",
    "moonTrail_jupiter",
    "moonTrail_carpo",
    "moonTrail_minor",
    "moonTrail_minor_jupiter"
  },
  GUI = {
    Name = "S/2018 J 4 Trail",
    Path = "/Solar System/Planets/Jupiter/Minor Moons/Carpo Group/S2018J4",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(CarpoTrail)
  openspace.addSceneGraphNode(S2018J4Trail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(S2018J4Trail)
  openspace.removeSceneGraphNode(CarpoTrail)
end)

asset.export(CarpoTrail)
asset.export(S2018J4Trail)



asset.meta = {
  Name = "Jupiter Carpo Group Moons Trails",
  Description = [[Asset containing trails for Jupiter's Carpo Group moons.]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
