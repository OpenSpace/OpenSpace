local S2018J4LabelNear = {
  Identifier = "S2018J4LabelNear",
  Parent = transforms.S2018J4Position.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "S2018J4",
    FontSize = 70.0,
    Size = 5.5,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
