    "minor_moon_labels_carpo"
  },
  GUI = {
    Name = "Carpo Label (Near)",
    Path = "/Solar System/Planets/Jupiter/Minor Moons/Carpo Group/Carpo",
    Focusable = false,
    Description = "Transitional Label for close-range viewing of Carpo (Carpo group)"
  }
}

