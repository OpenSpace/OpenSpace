local transforms = asset.require("./transforms")



local HerseLabel = {
  Identifier = "HerseLabel",
  Parent = transforms.HersePosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Herse",
    FontSize = 70.0,
    Size = 7.1,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
