  openspace.removeSceneGraphNode(ArchePosition)
  openspace.removeSceneGraphNode(EukeladePosition)
  openspace.removeSceneGraphNode(S2010J1Position)
  openspace.removeSceneGraphNode(PasitheePosition)
  openspace.removeSceneGraphNode(KalykePosition)
  openspace.removeSceneGraphNode(KallichorePosition)
  openspace.removeSceneGraphNode(ErinomePosition)
  openspace.removeSceneGraphNode(ChaldenePosition)
  openspace.removeSceneGraphNode(TaygetePosition)
  openspace.removeSceneGraphNode(KalePosition)
  openspace.removeSceneGraphNode(AitnePosition)
  openspace.removeSceneGraphNode(HersePosition)
end)

