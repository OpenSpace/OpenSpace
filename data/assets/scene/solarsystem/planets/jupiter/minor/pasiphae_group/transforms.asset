asset.onInitialize(function()
  openspace.addSceneGraphNode(EuporiePosition)
  openspace.addSceneGraphNode(S2003J18Position)
  openspace.addSceneGraphNode(HelikePosition)
  openspace.addSceneGraphNode(OrthosiePosition)
  openspace.addSceneGraphNode(S2016J1Position)
