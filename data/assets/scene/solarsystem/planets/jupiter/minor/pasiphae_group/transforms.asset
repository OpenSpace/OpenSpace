  openspace.addSceneGraphNode(AutonoePosition)
  openspace.addSceneGraphNode(MegaclitePosition)
  openspace.addSceneGraphNode(S2016J4Position)
  openspace.addSceneGraphNode(S2017J6Position)
  openspace.addSceneGraphNode(S2003J23Position)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(S2003J23Position)
  openspace.removeSceneGraphNode(S2017J6Position)
  openspace.removeSceneGraphNode(S2016J4Position)
  openspace.removeSceneGraphNode(MegaclitePosition)
  openspace.removeSceneGraphNode(AutonoePosition)
  openspace.removeSceneGraphNode(SpondePosition)
  openspace.removeSceneGraphNode(SinopePosition)
  openspace.removeSceneGraphNode(HegemonePosition)
  openspace.removeSceneGraphNode(PasiphaePosition)
  openspace.removeSceneGraphNode(S2003J4Position)
  openspace.removeSceneGraphNode(S2017J1Position)
  openspace.removeSceneGraphNode(S2011J2Position)
  openspace.removeSceneGraphNode(CyllenePosition)
  openspace.removeSceneGraphNode(KorePosition)
  openspace.removeSceneGraphNode(EurydomePosition)
  openspace.removeSceneGraphNode(CallirrhoePosition)
  openspace.removeSceneGraphNode(AoedePosition)
  openspace.removeSceneGraphNode(S2003J15Position)
  openspace.removeSceneGraphNode(S2016J1Position)
  openspace.removeSceneGraphNode(OrthosiePosition)
  openspace.removeSceneGraphNode(HelikePosition)
  openspace.removeSceneGraphNode(S2003J18Position)
  openspace.removeSceneGraphNode(EuporiePosition)
end)

