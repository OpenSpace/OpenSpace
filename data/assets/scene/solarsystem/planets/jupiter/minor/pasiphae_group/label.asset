local transforms = asset.require("./transforms")



local EuporieLabel = {
  Identifier = "EuporieLabel",
  Parent = transforms.EuporiePosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Euporie",
    FontSize = 70.0,
    Size = 7.1,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 1.5, 140.0 },
    FadeWidths = { 0.5, 50.0 }
  },
  Tag = {
