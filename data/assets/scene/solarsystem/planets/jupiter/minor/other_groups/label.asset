local ValetudoLabel = {
  Identifier = "ValetudoLabel",
  Parent = transforms.ValetudoPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = false,
    Text = "Valetudo",
    FontSize = 70.0,
    Size = 7.1,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 1.0, 150.0 },
    FadeWidths = { 1.0, 50.0 }
  },
  Tag = {
    "solarsystem_labels",
    "moon_labels",
