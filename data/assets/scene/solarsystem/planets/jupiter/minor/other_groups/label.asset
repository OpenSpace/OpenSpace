asset.onInitialize(function()
  openspace.addSceneGraphNode(EuphemeLabel)
  openspace.addSceneGraphNode(S2003J19Label)
  openspace.addSceneGraphNode(ValetudoLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(ValetudoLabel)
  openspace.removeSceneGraphNode(S2003J19Label)
  openspace.removeSceneGraphNode(EuphemeLabel)
end)

asset.export(EuphemeLabel)
asset.export(S2003J19Label)
asset.export(ValetudoLabel)



asset.meta = {
  Name = "Jupiter Pasiphae Other Moons Labels",
  Description = [[Asset containing labels for Jupiter's Other Group moons.]],
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
