local transforms = asset.require("scene/solarsystem/planets/jupiter/transforms")
local kernels347 = asset.require("scene/solarsystem/planets/jupiter/kernels347")
local coreKernels = asset.require("spice/core")



local EuphemeTrail = {
  Identifier = "EuphemeTrail",
  Parent = transforms.JupiterBarycenter.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels347.ID.Eupheme,
      Observer = coreKernels.ID.JupiterBarycenter
    },
    Color = { 0.4, 0.3, 0.01 },
    Period = 628.06,
    Resolution = 1000
  },
  Tag = {
    "moonTrail_solarSystem",
    "moonTrail_giants",
    "moonTrail_jupiter",
    "moonTrail_other",
    "moonTrail_minor",
    "moonTrail_minor_jupiter"
  },
  GUI = {
    Name = "Eupheme Trail",
    Path = "/Solar System/Planets/Jupiter/Minor Moons/Other Group/Eupheme",
    Focusable = false
  }
}

local S2003J19Trail = {
  Identifier = "S2003J19Trail",
  Parent = transforms.JupiterBarycenter.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels347.ID.S2003J19,
      Observer = coreKernels.ID.JupiterBarycenter
    },
    Color = { 0.4, 0.3, 0.01 },
    Period = 699.12,
    Resolution = 1000
  },
  Tag = {
    "moonTrail_solarSystem",
    "moonTrail_giants",
    "moonTrail_jupiter",
    "moonTrail_other",
    "moonTrail_minor",
    "moonTrail_minor_jupiter"
  },
  GUI = {
    Name = "S/2003 J 19 Trail",
    Path = "/Solar System/Planets/Jupiter/Minor Moons/Ananke Group/S2003J19",
    Focusable = false
  }
}

local ValetudoTrail = {
  Identifier = "ValetudoTrail",
  Parent = transforms.JupiterBarycenter.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels347.ID.Valetudo,
      Observer = coreKernels.ID.JupiterBarycenter
    },
    Color = { 0.4, 0.3, 0.01 },
    Period = 527.41,
    Resolution = 1000
  },
  Tag = {
    "moonTrail_solarSystem",
    "moonTrail_giants",
    "moonTrail_jupiter",
    "moonTrail_other",
    "moonTrail_minor",
    "moonTrail_minor_jupiter"
  },
  GUI = {
    Name = "Valetudo Trail",
    Path = "/Solar System/Planets/Jupiter/Minor Moons/Ananke Group/Valetudo",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(EuphemeTrail)
  openspace.addSceneGraphNode(S2003J19Trail)
  openspace.addSceneGraphNode(ValetudoTrail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(ValetudoTrail)
  openspace.removeSceneGraphNode(S2003J19Trail)
  openspace.removeSceneGraphNode(EuphemeTrail)
end)

asset.export(EuphemeTrail)
asset.export(S2003J19Trail)
asset.export(ValetudoTrail)



asset.meta = {
  Name = "Jupiter Pasiphae Other Moons Trails",
  Description = [[Asset containing trails for Jupiter's Other Group moons.]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
