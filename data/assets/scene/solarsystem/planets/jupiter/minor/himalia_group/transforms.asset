asset.onInitialize(function()
  openspace.addSceneGraphNode(LedaPosition)
  openspace.addSceneGraphNode(HimaliaPosition)
  openspace.addSceneGraphNode(LysitheaPosition)
  openspace.addSceneGraphNode(ElaraPosition)
  openspace.addSceneGraphNode(DiaPosition)
  openspace.addSceneGraphNode(S2011J3Position)
  openspace.addSceneGraphNode(S2018J2Position)
  openspace.addSceneGraphNode(PandiaPosition)
  openspace.addSceneGraphNode(ErsaPosition)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(ErsaPosition)
  openspace.removeSceneGraphNode(PandiaPosition)
  openspace.removeSceneGraphNode(S2018J2Position)
  openspace.removeSceneGraphNode(S2011J3Position)
  openspace.removeSceneGraphNode(DiaPosition)
  openspace.removeSceneGraphNode(ElaraPosition)
  openspace.removeSceneGraphNode(LysitheaPosition)
  openspace.removeSceneGraphNode(HimaliaPosition)
  openspace.removeSceneGraphNode(LedaPosition)
end)

asset.export(LedaPosition)
asset.export(HimaliaPosition)
asset.export(LysitheaPosition)
asset.export(ElaraPosition)
asset.export(DiaPosition)
asset.export(S2011J3Position)
asset.export(S2018J2Position)
asset.export(PandiaPosition)
asset.export(ErsaPosition)



asset.meta = {
  Name = "Jupiter Himalia Group Moons Positions",
  Description = [[Asset containing positions for Jupiter's Himalia Group moons.]],
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
