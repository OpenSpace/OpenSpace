asset.onInitialize(function()
  openspace.addSceneGraphNode(S2010J2Position)
  openspace.addSceneGraphNode(ThelxinoePosition)
  openspace.addSceneGraphNode(EuanthePosition)
  openspace.addSceneGraphNode(IocastePosition)
  openspace.addSceneGraphNode(S2003J16Position)
  openspace.addSceneGraphNode(PraxidikePosition)
  openspace.addSceneGraphNode(HarpalykePosition)
  openspace.addSceneGraphNode(MnemePosition)
  openspace.addSceneGraphNode(HermippePosition)
  openspace.addSceneGraphNode(ThyonePosition)
  openspace.addSceneGraphNode(AnankePosition)
  openspace.addSceneGraphNode(S2021J1Position)
  openspace.addSceneGraphNode(S2021J2Position)
  openspace.addSceneGraphNode(S2021J3Position)
  openspace.addSceneGraphNode(S2022J3Position)
  openspace.addSceneGraphNode(S2017J3Position)
  openspace.addSceneGraphNode(S2017J7Position)
  openspace.addSceneGraphNode(S2017J9Position)
  openspace.addSceneGraphNode(S2003J2Position)
  openspace.addSceneGraphNode(S2003J12Position)
  openspace.addSceneGraphNode(S2017J10Position)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(S2017J10Position)
  openspace.removeSceneGraphNode(S2003J12Position)
  openspace.removeSceneGraphNode(S2003J2Position)
  openspace.removeSceneGraphNode(S2017J9Position)
  openspace.removeSceneGraphNode(S2017J7Position)
  openspace.removeSceneGraphNode(S2017J3Position)
  openspace.removeSceneGraphNode(S2022J3Position)
  openspace.removeSceneGraphNode(S2021J3Position)
  openspace.removeSceneGraphNode(S2021J2Position)
  openspace.removeSceneGraphNode(S2021J1Position)
  openspace.removeSceneGraphNode(AnankePosition)
  openspace.removeSceneGraphNode(ThyonePosition)
  openspace.removeSceneGraphNode(HermippePosition)
  openspace.removeSceneGraphNode(MnemePosition)
  openspace.removeSceneGraphNode(HarpalykePosition)
  openspace.removeSceneGraphNode(PraxidikePosition)
  openspace.removeSceneGraphNode(S2003J16Position)
  openspace.removeSceneGraphNode(IocastePosition)
  openspace.removeSceneGraphNode(EuanthePosition)
  openspace.removeSceneGraphNode(ThelxinoePosition)
  openspace.removeSceneGraphNode(S2010J2Position)
end)

