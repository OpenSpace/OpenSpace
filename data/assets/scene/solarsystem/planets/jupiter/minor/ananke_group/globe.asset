  openspace.addSceneGraphNode(S2003J2)
  openspace.addSceneGraphNode(S2003J12)
  openspace.addSceneGraphNode(S2017J10)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(S2017J10)
  openspace.removeSceneGraphNode(S2003J12)
  openspace.removeSceneGraphNode(S2003J2)
  openspace.removeSceneGraphNode(S2017J9)
  openspace.removeSceneGraphNode(S2017J7)
  openspace.removeSceneGraphNode(S2017J3)
  openspace.removeSceneGraphNode(S2022J3)
  openspace.removeSceneGraphNode(S2021J3)
  openspace.removeSceneGraphNode(S2021J2)
  openspace.removeSceneGraphNode(S2021J1)
  openspace.removeSceneGraphNode(Ananke)
  openspace.removeSceneGraphNode(Thyone)
  openspace.removeSceneGraphNode(Hermippe)
  openspace.removeSceneGraphNode(Mneme)
  openspace.removeSceneGraphNode(Harpalyke)
  openspace.removeSceneGraphNode(Praxidike)
  openspace.removeSceneGraphNode(S2003J16)
  openspace.removeSceneGraphNode(Iocaste)
  openspace.removeSceneGraphNode(Euanthe)
  openspace.removeSceneGraphNode(Thelxinoe)
  openspace.removeSceneGraphNode(S2010J2)
end)

