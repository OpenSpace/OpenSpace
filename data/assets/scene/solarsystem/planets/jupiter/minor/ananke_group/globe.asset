asset.onInitialize(function()
  openspace.addSceneGraphNode(S2010J2)
  openspace.addSceneGraphNode(Thelxinoe)
  openspace.addSceneGraphNode(Euanthe)
  openspace.addSceneGraphNode(Iocaste)
  openspace.addSceneGraphNode(S2003J16)
