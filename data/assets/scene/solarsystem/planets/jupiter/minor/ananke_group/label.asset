asset.onInitialize(function()
  openspace.addSceneGraphNode(S2010J2Label)
  openspace.addSceneGraphNode(ThelxinoeLabel)
  openspace.addSceneGraphNode(EuantheLabel)
  openspace.addSceneGraphNode(IocasteLabel)
  openspace.addSceneGraphNode(S2003J16Label)
  openspace.addSceneGraphNode(PraxidikeLabel)
  openspace.addSceneGraphNode(HarpalykeLabel)
  openspace.addSceneGraphNode(MnemeLabel)
  openspace.addSceneGraphNode(HermippeLabel)
  openspace.addSceneGraphNode(ThyoneLabel)
  openspace.addSceneGraphNode(AnankeLabel)
  openspace.addSceneGraphNode(S2021J1Label)
  openspace.addSceneGraphNode(S2021J2Label)
  openspace.addSceneGraphNode(S2021J3Label)
  openspace.addSceneGraphNode(S2022J3Label)
  openspace.addSceneGraphNode(S2017J3Label)
  openspace.addSceneGraphNode(S2017J7Label)
  openspace.addSceneGraphNode(S2017J9Label)
  openspace.addSceneGraphNode(S2003J2Label)
  openspace.addSceneGraphNode(S2003J12Label)
  openspace.addSceneGraphNode(S2017J10Label)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(S2017J10Label)
  openspace.removeSceneGraphNode(S2003J12Label)
  openspace.removeSceneGraphNode(S2003J2Label)
  openspace.removeSceneGraphNode(S2017J9Label)
  openspace.removeSceneGraphNode(S2017J7Label)
  openspace.removeSceneGraphNode(S2017J3Label)
  openspace.removeSceneGraphNode(S2022J3Label)
  openspace.removeSceneGraphNode(S2021J3Label)
  openspace.removeSceneGraphNode(S2021J2Label)
  openspace.removeSceneGraphNode(S2021J1Label)
  openspace.removeSceneGraphNode(AnankeLabel)
  openspace.removeSceneGraphNode(ThyoneLabel)
  openspace.removeSceneGraphNode(HermippeLabel)
  openspace.removeSceneGraphNode(MnemeLabel)
  openspace.removeSceneGraphNode(HarpalykeLabel)
  openspace.removeSceneGraphNode(PraxidikeLabel)
  openspace.removeSceneGraphNode(S2003J16Label)
  openspace.removeSceneGraphNode(IocasteLabel)
  openspace.removeSceneGraphNode(EuantheLabel)
  openspace.removeSceneGraphNode(ThelxinoeLabel)
  openspace.removeSceneGraphNode(S2010J2Label)
end)

