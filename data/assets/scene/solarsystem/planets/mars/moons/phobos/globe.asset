local transforms = asset.require("./transforms")



local Phobos = {
  Identifier = "Phobos",
  Parent = transforms.PhobosTransform.Identifier,
  Renderable = {
    Type = "RenderableGlobe",
    -- Radius source
    -- https://naif.jpl.nasa.gov/pub/naif/generic_kernels/dsk/satellites/willner_etal_phobos.pdf
    Radii = { 13030, 11400, 9140 }
  },
  Tag = { "moon_solarSystem", "moon_terrestrial", "moon_mars" },
  GUI = {
    Name = "Phobos",
    Path = "/Solar System/Planets/Mars/Moons/Phobos",
    Description = "One of two moons of Mars"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(Phobos)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(Phobos)
end)

asset.export(Phobos)



asset.meta = {
  Name = "Phobos Globe",
  Description = "RenderableGlobe for Phobos",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
