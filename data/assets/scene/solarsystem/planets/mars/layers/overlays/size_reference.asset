local marsAsset = asset.require("scene/solarsystem/planets/mars/globe")



local Layer = {
  Identifier = "Size_Reference",
  Name = "Size Reference",
  Enabled = asset.enabled,
  Type = "SizeReferenceTileProvider",
  Radii = marsAsset.Mars.Renderable.Radii
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(marsAsset.Mars.Identifier, "Overlays", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(marsAsset.Mars.Identifier, "Overlays", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Mars Size Reference",
  Description = "This asset supplies a size reference layer for the Mars globe",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
