local marsAsset = asset.require("scene/solarsystem/planets/mars/globe")



local data = asset.resource({
  Name = "HiRISE Mojave Crater - Delta Structures",
  Type = "HttpSynchronization",
  Identifier = "mars_hirise_mojave_crater-dissected_wall",
  Version = 1
})


local ColorLayer = {
  Identifier = "Mojave_Crater",
  Name = "Mojave Crater [Local]",
  Enabled = asset.enabled,
  ZIndex = 65,
  FilePath = data .. "Dissected_Wall_of_Mojave_Crater_Texture.vrt",
  BlendMode = "Color"
}

local HeightLayer = {
  Identifier = "Mojave_Crater",
  Name = "Mojave Crater [Local]",
  Enabled = asset.enabled,
  ZIndex = 65,
  FilePath = data .. "Dissected_Wall_of_Mojave_Crater_Heightmap.vrt"
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(marsAsset.Mars.Identifier, "ColorLayers", ColorLayer)
  openspace.globebrowsing.addLayer(marsAsset.Mars.Identifier, "HeightLayers", HeightLayer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(marsAsset.Mars.Identifier, "HeightLayers", HeightLayer)
  openspace.globebrowsing.deleteLayer(marsAsset.Mars.Identifier, "ColorLayers", ColorLayer)
end)



asset.meta = {
  Name = "HiRISE Dissected Wall of Mojave Crater [Local]",
  Description = [[A local layer for Dissected Wall of Mojave Crater from the HiRISE instrument.]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
