local earthAsset = asset.require("scene/solarsystem/planets/earth/earth")



local Layer = {
  Name = "Gebco [New York]",
  Identifier = "Gebco_NewYork",
  Enabled = asset.enabled,
  ZIndex = 10,
  FilePath = asset.resource("gebco_newyork.wms")
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(earthAsset.Earth.Identifier, "WaterMasks", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(earthAsset.Earth.Identifier, "WaterMasks", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Gebco WaterMask Layer (New York)",
  Description = "WaterMask layer for Earth globe",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
