local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite OMM Data (Beidou)",
  Type = "UrlSynchronization",
  Identifier = "satellite_omm_data_beidou",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=beidou&FORMAT=kvn",
  Filename = "beidou.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local BeidouSatellites = {
  Identifier = "BeidouSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "beidou.txt",
    Format = "OMM",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 15,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Beidou",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(BeidouSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(BeidouSatellites)
end)

asset.export(BeidouSatellites)



asset.meta = {
  Name = "Satellites Navigation Beidou",
  Description = "Satellites asset for Navigation Beidou. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
