local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite CSV Data (GNSS)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_gnss",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=gnss&FORMAT=csv",
  Filename = "gnss.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local GNSSSatellites = {
  Identifier = "GNSSSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "gnss.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.9, 0.5, 0.0 },
    TrailFade = 15,
    PointSizeExponent = 5.5,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "GNSS",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false,
    Description = [[The GPS satellites that give us our precise locations back on Earth.]]
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(GNSSSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(GNSSSatellites)
end)

asset.export(GNSSSatellites)



asset.meta = {
  Name = "Satellites Navigation GNSS",
  Description = "Satellites asset for Navigation GNSS. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
