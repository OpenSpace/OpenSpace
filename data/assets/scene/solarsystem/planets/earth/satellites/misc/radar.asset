local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite CSV Data (Radar Calibration)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_radar",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=radar&FORMAT=csv",
  Filename = "radar.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local RadarSatellites = {
  Identifier = "RadarSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "radar.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 15,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Radar Calibration",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(RadarSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(RadarSatellites)
end)

asset.export(RadarSatellites)



asset.meta = {
  Name = "Satellites Radar Calibration",
  Description = "Satellites asset for Radar Calibration. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
