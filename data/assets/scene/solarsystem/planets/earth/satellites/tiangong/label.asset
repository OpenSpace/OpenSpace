local transforms = asset.require("./transforms")


local TiangongLabel = {
  Identifier = "TiangongLabel",
  Parent = transforms.TiangongPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Tiangong",
    FontSize = 70.0,
    Size = 3.4,
    MinMaxSize = { 1, 100 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeDistances = { 0.15, 15.0 },
    FadeWidths = { 1.0, 25.0 }
  },
  Tag = {
    "solarsystem_labels",
    "earth_satellites",
    "Tiangong",
    "space_stations",
    "labels"
  },
  GUI = {
    Name = "Tiangong Label",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(TiangongLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TiangongLabel)
end)

asset.export(TiangongLabel)



asset.meta = {
  Name = "Tiangong Label",
  Description = [[Label for Tiangong.]],
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/"
}
