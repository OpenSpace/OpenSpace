local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite CSV Data (Amateur Radio)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_amateur_radio",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=amateur&FORMAT=csv",
  Filename = "amateur.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local AmateurSatellites = {
  Identifier = "AmateurSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "amateur.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 15.0,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Amateur Radio",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(AmateurSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(AmateurSatellites)
end)

asset.export(AmateurSatellites)



asset.meta = {
  Name = "Satellites Communications - Amateur Radio",
  Description = [[Satellites asset for Communications - Amateur Radio. Data from
    Celestrak]],
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
