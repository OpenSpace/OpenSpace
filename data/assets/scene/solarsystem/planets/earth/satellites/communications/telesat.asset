local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite OMM Data (Telesat)",
  Type = "UrlSynchronization",
  Identifier = "satellite_omm_data_telesat",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=telesat&FORMAT=csv",
  Filename = "telesat.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local TelesatSatellites = {
  Identifier = "TelesatSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "telesat.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 5,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Telesat",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(TelesatSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TelesatSatellites)
end)

asset.export(TelesatSatellites)



asset.meta = {
  Name = "Satellites Communications - Telesat",
  Description = "Satellites asset for Communications - Telesat. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
