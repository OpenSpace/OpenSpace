local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite CSV Data (Iridium NEXT)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_iridium-NEXT",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=iridium-NEXT&FORMAT=csv",
  Filename = "iridium-NEXT.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local IridiumNextSatellites = {
  Identifier = "IridiumNextSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "iridium-NEXT.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 15,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Iridium NEXT",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(IridiumNextSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(IridiumNextSatellites)
end)

asset.export(IridiumNextSatellites)



asset.meta = {
  Name = "Satellites Communications - Iridium NEXT",
  Description = "Satellites asset for Communications - Iridium NEXT. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
