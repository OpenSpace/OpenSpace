local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite CSV Data (SES)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_ses",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=ses&FORMAT=csv",
  Filename = "ses.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local SesSatellites = {
  Identifier = "SesSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "ses.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 10,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "SES",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(SesSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(SesSatellites)
end)

asset.export(SesSatellites)



asset.meta = {
  Name = "Satellites Communications - SES",
  Description = "Satellites asset for Communications - SES. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
