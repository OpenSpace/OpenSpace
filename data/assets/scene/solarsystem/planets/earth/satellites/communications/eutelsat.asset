local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite OMM Data (Eutelsat)",
  Type = "UrlSynchronization",
  Identifier = "satellite_omm_data_eutelsat",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=eutelsat&FORMAT=csv",
  Filename = "eutelsat.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local EutelsatSatellites = {
  Identifier = "EutelsatSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "eutelsat.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 5,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Eutelsat",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(EutelsatSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(EutelsatSatellites)
end)

asset.export(EutelsatSatellites)



asset.meta = {
  Name = "Satellites Communications - Eutelsat",
  Description = "Satellites asset for Communications - Eutelsat. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
