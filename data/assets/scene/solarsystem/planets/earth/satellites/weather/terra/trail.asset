local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")
local coreKernels = asset.require("spice/core")



local omm = asset.resource({
  Name = "Satellite CSV Data (Terra)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_terra",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?CATNR=25994&FORMAT=csv",
  Filename = "Terra.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local TerraTrail = {
  Identifier = "Terra_trail",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "GPTranslation",
      Observer = earthAsset.EarthInertial.Identifier,
      File = omm .. "Terra.txt",
      Format = "CSV",
      RenderBinMode = "PostDeferredTransparent"
    },
    Color = { 0.9, 0.6715, 0.0 },
    Fade = 1.5,
    Resolution = 320
  },
  Tag = { "earth_satellites", "Terra" },
  GUI = {
    Name = "Terra Trail",
    Path = "/Solar System/Planets/Earth/Satellites/Terra",
    Focusable = false
  }
}


asset.onInitialize(function()
  local t = openspace.space.readKeplerFile(omm .. "Terra.txt", "CSV")
  TerraTrail.Renderable.Period = t[1].Period / (60 * 60 * 24)

  openspace.addSceneGraphNode(TerraTrail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TerraTrail)
end)

asset.export(TerraTrail)



asset.meta = {
  Name = "Terra Trail",
  Description = [[Trail for Terra. Trail data from Celestrak. Can be used in conjuntion
    with Terra Modis (Temporal) layer for Earth]],
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/",
  License = "NASA"
}
