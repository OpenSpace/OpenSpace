local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")
local coreKernels = asset.require("spice/core")



local omm = asset.resource({
  Name = "Satellite OMM Data (Aqua)",
  Type = "UrlSynchronization",
  Identifier = "satellite_omm_data_aqua",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?CATNR=27424&FORMAT=kvn",
  Filename = "Aqua.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local AquaPosition = {
  Identifier = "AquaPosition",
  Parent = earthAsset.EarthInertial.Identifier,
  InteractionSphere = 30,
  Transform = {
    Translation = {
      Type = "GPTranslation",
      Observer = earthAsset.EarthInertial.Identifier,
      File = omm .. "Aqua.txt",
      Format = "OMM"
    },
    Rotation = {
      Type = "SpiceRotation",
      SourceFrame = coreKernels.Frame.Galactic,
      DestinationFrame = coreKernels.Frame.J2000
    }
  },
  Tag = { "earth_satellites", "Aqua" },
  GUI = {
    Name = "Aqua",
    Path = "/Solar System/Planets/Earth/Satellites/Aqua"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(AquaPosition)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(AquaPosition)
end)

asset.export(AquaPosition)



asset.meta = {
  Name = "Aqua Position",
  Description = [[Position for Aqua. Can be used in conjuntion with Aqua Modis (Temporal)
    layer for Earth]],
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/",
  License = "NASA"
}
