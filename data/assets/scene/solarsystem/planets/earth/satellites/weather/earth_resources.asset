local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite CSV Data (Earth Resources)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_resource",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=resource&FORMAT=csv",
  Filename = "resource.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local ResourceSatellites = {
  Identifier = "ResourceSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "resource.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 15,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Earth Resources",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(ResourceSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(ResourceSatellites)
end)

asset.export(ResourceSatellites)



asset.meta = {
  Name = "Satellites Weather - Earth Resources",
  Description = "Satellites asset for Weather - Earth Resources. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
