local transforms = asset.require("./transforms")



local TerraLabel = {
  Identifier = "TerraLabel",
  Parent = transforms.TerraPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Text = "Terra",
    FontSize = 70.0,
    Size = 4.0,
    MinMaxSize = { 1, 100 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "au",
    FadeDistances = { 1.5, 15.0 },
    FadeWidths = { 1.0, 25.0 }
  },
  Tag = { "solarsystem_labels" },
  GUI = {
    Name = "Terra Label",
    Path = "/Solar System/Planets/Earth/Satellites/Terra",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(TerraLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TerraLabel)
end)

asset.export(TerraLabel)



asset.meta = {
  Name = "Terra Label",
  Description = [[Label for Terra. Can be used in conjuntion with Terra Modis (Temporal)
    layer for Earth]],
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/",
  License = "NASA"
}
