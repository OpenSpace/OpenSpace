local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite OMM Data (Search & Rescue (SARSAT))",
  Type = "UrlSynchronization",
  Identifier = "satellite_omm_data_sarsat",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=sarsat&FORMAT=csv",
  Filename = "sarsat.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local SarSatellites = {
  Identifier = "SarSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "sarsat.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 10,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Search & Rescue (SARSAT)",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(SarSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(SarSatellites)
end)

asset.export(SarSatellites)



asset.meta = {
  Name = "Satellites Weather - Search & Rescue (SARSAT)",
  Description = [[Satellites asset for Weather - Search & Rescue (SARSAT). Data from
    Celestrak]],
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
