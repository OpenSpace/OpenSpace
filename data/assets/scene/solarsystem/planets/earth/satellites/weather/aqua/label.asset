local transforms = asset.require("./transforms")
local coreKernels = asset.require("spice/core")



local AquaLabel = {
  Identifier = "AquaLabel",
  Parent = transforms.AquaPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Aqua",
    FontSize = 70.0,
    Size = 4.0,
    MinMaxSize = { 1, 100 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "au",
    FadeDistances = { 1.5, 15.0 },
    FadeWidths = { 1.0, 25.0 }
  },
  Tag = { "solarsystem_labels" },
  GUI = {
    Name = "Aqua Label",
    Path = "/Solar System/Planets/Earth"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(AquaLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(AquaLabel)
end)

asset.export(AquaLabel)



asset.meta = {
  Name = "Aqua Label",
  Description = [[Label for Aqua.]],
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/",
  License = "NASA"
}
