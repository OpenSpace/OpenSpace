local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")
local coreKernels = asset.require("spice/core")



local omm = asset.resource({
  Name = "Satellite CSV Data (Terra)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_terra",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?CATNR=25994&FORMAT=csv",
  Filename = "Terra.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local TerraPosition = {
  Identifier = "TerraPosition",
  Parent = earthAsset.EarthInertial.Identifier,
  InteractionSphere = 30,
  Transform = {
    Translation = {
      Type = "GPTranslation",
      Observer = earthAsset.EarthInertial.Identifier,
      File = omm .. "Terra.txt",
      Format = "CSV"
    },
    Rotation = {
      Type = "SpiceRotation",
      SourceFrame = coreKernels.Frame.Galactic,
      DestinationFrame = coreKernels.Frame.J2000
    }
  },
  Tag = { "earth_satellites", "Terra" },
  GUI = {
    Name = "Terra",
    Path = "/Solar System/Planets/Earth/Satellites/Terra"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(TerraPosition)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TerraPosition)
end)

asset.export(TerraPosition)



asset.meta = {
  Name = "Terra Position",
  Description = [[Position for Terra. Can be used in conjuntion with Terra Modis
    (Temporal) layer for Earth]],
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/",
  License = "NASA"
}
