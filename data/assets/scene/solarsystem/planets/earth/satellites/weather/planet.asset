local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite OMM Data (Planet)",
  Type = "UrlSynchronization",
  Identifier = "satellite_omm_data_planet",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=planet&FORMAT=csv",
  Filename = "planet.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local PlanetSatellites = {
  Identifier = "PlanetSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "planet.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 15,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Planet",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(PlanetSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(PlanetSatellites)
end)

asset.export(PlanetSatellites)



asset.meta = {
  Name = "Satellites Weather - Planet",
  Description = "Satellites asset for Weather - Planet. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
