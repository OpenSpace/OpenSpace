local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite CSV Data (Geodetic)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_geodetic",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?GROUP=geodetic&FORMAT=csv",
  Filename = "geodetic.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local GeodeticSatellites = {
  Identifier = "GeodeticSatellites",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableOrbitalKepler",
    Path = omm .. "geodetic.txt",
    Format = "CSV",
    SegmentQuality = 3,
    Color = { 0.75, 0.75, 0.35 },
    TrailFade = 20,
    PointSizeExponent = 5.0,
    RenderBinMode = "PostDeferredTransparent"
  },
  Tag = { "earth_satellites" },
  GUI = {
    Name = "Geodetic",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(GeodeticSatellites)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(GeodeticSatellites)
end)

asset.export(GeodeticSatellites)



asset.meta = {
  Name = "Satellites Science Geodect",
  Description = "Satellites asset for Science Geodect. Data from Celestrak",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "Celestrak"
}
