local transforms = asset.require("./transforms")



local IssLabel = {
  Identifier = "IssLabel",
  Parent = transforms.ISSPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "ISS",
    FontSize = 70.0,
    Size = 3.4,
    MinMaxSize = { 1, 100 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeDistances = { 0.15, 15.0 },
    FadeWidths = { 1.0, 25.0 }
  },
  Tag = { "solarsystem_labels", "earth_satellites", "ISS", "space_stations", "labels" },
  GUI = {
    Name = "ISS Label",
    Path = "/Solar System/Planets/Earth/Satellites",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(IssLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(IssLabel)
end)

asset.export(IssLabel)



asset.meta = {
  Name = "International Space Station Label",
  Description = "Label for the International Space Station",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "CC-BY"
}
