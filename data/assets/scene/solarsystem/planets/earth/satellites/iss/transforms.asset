local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite OMM Data (ISS)",
  Type = "UrlSynchronization",
  Identifier = "satellite_omm_data_iss",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?CATNR=25544&FORMAT=csv",
  Filename = "ISS.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local IssPosition = {
  Identifier = "ISSPosition",
  Parent = earthAsset.EarthInertial.Identifier,
  BoundingSphere = 54.5, -- half the width
  Transform = {
    Translation = {
      Type = "GPTranslation",
      Observer = earthAsset.EarthInertial.Identifier,
      File = omm .. "ISS.txt",
      Format = "CSV"
    }
  },
  Tag = { "earth_satellites", "ISS", "space_stations" },
  GUI = {
    Name = "ISS Position",
    Path = "/Solar System/Planets/Earth/Satellites/ISS",
    Hidden = true
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(IssPosition)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(IssPosition)
end)

asset.export(IssPosition)



asset.meta = {
  Name = "International Space Station Position",
  Description = "Position for ISS. Data from Celestrak.",
  Author = "OpenSpace Team",
  URL = "https://celestrak.org/NORAD/elements/",
  License = "CC-BY"
}
