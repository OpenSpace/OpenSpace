local earthAsset = asset.require("scene/solarsystem/planets/earth/transforms")



local omm = asset.resource({
  Name = "Satellite CSV Data (Hubble)",
  Type = "UrlSynchronization",
  Identifier = "satellite_csv_data_hst",
  Url = "https://liu-se.relay.openspaceproject.com/celestrak?CATNR=20580&FORMAT=csv",
  Filename = "hst.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})


local HubbleTrail = {
  Identifier = "HubbleTrail",
  Parent = earthAsset.EarthInertial.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "GPTranslation",
      Observer = earthAsset.EarthInertial.Identifier,
      File = omm .. "hst.txt",
      Format = "CSV"
    },
    RenderBinMode = "PostDeferredTransparent",
    Color = { 0.0, 0.902, 0.6 },
    Fade = 1.5,
    Resolution = 320
  },
  Tag = { "earth_satellites", "hubble" },
  GUI = {
    Name = "Hubble Trail",
    Path = "/Solar System/Planets/Earth/Satellites/Hubble",
    Focusable = false
  }
}


asset.onInitialize(function()
  local hubble = openspace.space.readKeplerFile(omm .. "hst.txt", "CSV")
  HubbleTrail.Renderable.Period = hubble[1].Period / (60 * 60 * 24)

  openspace.addSceneGraphNode(HubbleTrail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(HubbleTrail)
end)

asset.export(HubbleTrail)



asset.meta = {
  Name = "Hubble Space Telescope Trail",
  Description = "Trail for Hubble Space Telescope, trail from Celestrak",
  Author = "Dan Tell",
  URL = "www.calacademy.org",
  License = "CC-BY"
}
