local moonAsset = asset.require("scene/solarsystem/planets/earth/moon/globe")



local Layer = {
  Identifier = "Size_Reference",
  Name = "Size Reference",
  Enabled = asset.enabled,
  Type = "SizeReferenceTileProvider",
  Radii = moonAsset.Moon.Renderable.Radii
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(moonAsset.Moon.Identifier, "Overlays", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(moonAsset.Moon.Identifier, "Overlays", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "Moon Size Reference",
  Description = "Size reference layer for Moon globe",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
