local transforms = asset.require("./transforms")


local circle = asset.resource({
  Name = "Circle",
  Type = "HttpSynchronization",
  Identifier = "circle_image",
  Version = 1
})


local L3Small = {
  Identifier = "L3Small",
  Parent = transforms.L3Position.Identifier,
  Renderable = {
    Type = "RenderablePlaneImageLocal",
    Enabled = asset.enabled,
    Billboard = true,
    Size = 4000000,
    Texture = circle .. "circle.png",
    BlendMode = "Additive"
  },
  Tag = { "lagrange_points_earth", "lagrange_points_earth_l3_small" },
  GUI = {
    Name = "L3 Small",
    Path = "/Solar System/Planets/Earth/Lagrange Points"
  }
}

local L3 = {
  Identifier = "L3",
  Parent = transforms.L3Position.Identifier,
  Renderable = {
    Type = "RenderablePlaneImageLocal",
    Enabled = asset.enabled,
    Billboard = true,
    Size = 70000000,
    Texture = circle .. "circle.png",
    BlendMode = "Additive"
  },
  Tag = { "lagrange_points_earth", "lagrange_points_earth_l3" },
  GUI = {
    Name = "L3",
    Path = "/Solar System/Planets/Earth/Lagrange Points"
  }
}

local L3SmallLabel = {
  Identifier = "L3SmallLabel",
  Parent = transforms.L3Position.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "L3",
    FontSize = 50.0,
    Size = 6.0,
    MinMaxSize = { 1.0, 100.0 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Normal",
    EnableFading = false
  },
  Tag = { "lagrange_points_earth", "lagrange_points_earth_l3_small" },
  GUI = {
    Name = "L3 Small Label",
    Path = "/Solar System/Planets/Earth/Lagrange Points",
    Focusable = false,
    Description = "Small label for L3"
  }
}

local L3Label = {
  Identifier = "L3Label",
  Parent = transforms.L3Position.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "L3",
    FontSize = 50,
    Size = 7.5,
    MinMaxSize = { 1.0, 100.0 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Normal",
    EnableFading = false
  },
  Tag = { "lagrange_points_earth", "lagrange_points_earth_l3" },
  GUI = {
    Name = "L3 Label",
    Path = "/Solar System/Planets/Earth/Lagrange Points",
    Focusable = false,
    Description = "Main label for L3"
  }
}



asset.onInitialize(function()
  openspace.addSceneGraphNode(L3Small)
  openspace.addSceneGraphNode(L3)
  openspace.addSceneGraphNode(L3SmallLabel)
  openspace.addSceneGraphNode(L3Label)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(L3Label)
  openspace.removeSceneGraphNode(L3SmallLabel)
  openspace.removeSceneGraphNode(L3)
  openspace.removeSceneGraphNode(L3Small)
end)

asset.export(L3Small)
asset.export(L3)
asset.export(L3SmallLabel)
asset.export(L3Label)



asset.meta = {
  Name = "Lagrange point L3",
  Description = [[The indications of L3 positions as calculated based on Earth's
   position offset by half a year.]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
