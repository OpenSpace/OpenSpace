local transforms = asset.require("./transforms")
local coreKernels = asset.require("spice/core")



local UmbrielLabel = {
  Identifier = "UmbrielLabel",
  Parent = transforms.UmbrielPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Umbriel",
    FontSize = 70.0,
    Size = 7.4,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 1, 250.0 },
    FadeWidths = { 1, 250.0 }
  },
  Tag = { "solarsystem_labels", "moon_labels", "major_moon_labels" },
  GUI = {
    Name = "Umbriel Label",
    Path = "/Solar System/Planets/Uranus/Major Moons/Umbriel",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(UmbrielLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(UmbrielLabel)
end)

asset.export(UmbrielLabel)



asset.meta = {
  Name = "Miranda Label",
  Description = [[Miranda Label]],
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
