local transforms = asset.require("scene/solarsystem/planets/uranus/transforms")
local kernel = asset.require("scene/solarsystem/planets/uranus/kernels184")
local coreKernels = asset.require("spice/core")



local MargaretTrail = {
  Identifier = "MargaretTrail",
  Parent = transforms.UranusBarycenter.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernel.ID.Margaret,
      Observer = coreKernels.ID.UranusBarycenter
    },
    Color = { 0.60, 0.65, 0.84 },
    Period = 1694.8,
    Resolution = 1000
  },
  Tag = {
    "moonTrail_solarSystem",
    "moonTrail_giants",
    "moonTrail_uranus",
    "moonTrail_minor",
    "moonTrail_minor_uranus"
  },
  GUI = {
    Name = "Margaret Trail",
    Path = "/Solar System/Planets/Uranus/Minor Moons/Irregular Prograde Moons/Margaret",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(MargaretTrail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(MargaretTrail)
end)

asset.export(MargaretTrail)



asset.meta = {
  Name = "Uranus Irregular Prograde Moons Trails",
  Description = [[Asset containing trails for Uranus' irregular prograde moons.]],
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
