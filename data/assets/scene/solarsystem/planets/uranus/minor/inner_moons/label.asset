    EnableFading = true,
    FadeUnit = "Mm",
    FadeDistances = { 100.0, 500.0 },
    FadeWidths = { 25.0, 500.0 }
  },
  Tag = { "solarsystem_labels", "moon_labels", "minor_moon_labels" },
  GUI = {
    Name = "Cordelia Label",
    Path = "/Solar System/Planets/Uranus/Minor Moons/Inner Moons/Cordelia",
