asset.onInitialize(function()
  openspace.addSceneGraphNode(CordeliaPosition)
  openspace.addSceneGraphNode(OpheliaPosition)
  openspace.addSceneGraphNode(BiancaPosition)
  openspace.addSceneGraphNode(CressidaPosition)
  openspace.addSceneGraphNode(DesdemonaPosition)
  openspace.addSceneGraphNode(JulietPosition)
  openspace.addSceneGraphNode(PortiaPosition)
  openspace.addSceneGraphNode(RosalindPosition)
  openspace.addSceneGraphNode(CupidPosition)
  openspace.addSceneGraphNode(BelindaPosition)
  openspace.addSceneGraphNode(PerditaPosition)
  openspace.addSceneGraphNode(PuckPosition)
  openspace.addSceneGraphNode(MabPosition)
  openspace.addSceneGraphNode(S2025U1Position)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(CordeliaPosition)
  openspace.removeSceneGraphNode(OpheliaPosition)
  openspace.removeSceneGraphNode(BiancaPosition)
  openspace.removeSceneGraphNode(CressidaPosition)
  openspace.removeSceneGraphNode(DesdemonaPosition)
  openspace.removeSceneGraphNode(JulietPosition)
  openspace.removeSceneGraphNode(PortiaPosition)
  openspace.removeSceneGraphNode(RosalindPosition)
  openspace.removeSceneGraphNode(CupidPosition)
  openspace.removeSceneGraphNode(BelindaPosition)
  openspace.removeSceneGraphNode(PerditaPosition)
  openspace.removeSceneGraphNode(PuckPosition)
  openspace.removeSceneGraphNode(MabPosition)
  openspace.addSceneGraphNode(S2025U1Position)
end)

asset.export(CordeliaPosition)
asset.export(OpheliaPosition)
asset.export(BiancaPosition)
asset.export(CressidaPosition)
asset.export(DesdemonaPosition)
asset.export(JulietPosition)
asset.export(PortiaPosition)
asset.export(RosalindPosition)
asset.export(CupidPosition)
asset.export(BelindaPosition)
asset.export(PerditaPosition)
asset.export(PuckPosition)
asset.export(MabPosition)
asset.export(S2025U1Position)



asset.meta = {
  Name = "Uranus Irregular Retrograde Moons Positions",
  Description = [[Asset containing positions for Uranus' irregular retrograde moons.]],
