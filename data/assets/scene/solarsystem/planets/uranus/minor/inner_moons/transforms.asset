local coreKernels = asset.require("spice/core")



local CordeliaPosition = {
  Identifier = "CordeliaPosition",
  Parent = transforms.UranusBarycenter.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.Cordelia,
      Observer = coreKernels.ID.UranusBarycenter
    }
  },
  GUI = {
    Name = "Cordelia Position",
    Path = "/Solar System/Planets/Uranus/Minor Moons/Inner Moons/Cordelia",
    Focusable = false,
    Hidden = true
  }
}

