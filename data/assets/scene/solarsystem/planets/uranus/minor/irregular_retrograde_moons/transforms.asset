asset.onInitialize(function()
  openspace.addSceneGraphNode(FranciscoPosition)
  openspace.addSceneGraphNode(CalibanPosition)
  openspace.addSceneGraphNode(StephanoPosition)
  openspace.addSceneGraphNode(TrinculoPosition)
  openspace.addSceneGraphNode(SycoraxPosition)
  openspace.addSceneGraphNode(ProsperoPosition)
  openspace.addSceneGraphNode(SetebosPosition)
  openspace.addSceneGraphNode(FerdinandPosition)
  openspace.addSceneGraphNode(S2023U1Position)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(S2023U1Position)
  openspace.removeSceneGraphNode(FerdinandPosition)
  openspace.removeSceneGraphNode(SetebosPosition)
  openspace.removeSceneGraphNode(ProsperoPosition)
  openspace.removeSceneGraphNode(SycoraxPosition)
  openspace.removeSceneGraphNode(TrinculoPosition)
  openspace.removeSceneGraphNode(StephanoPosition)
  openspace.removeSceneGraphNode(CalibanPosition)
  openspace.removeSceneGraphNode(FranciscoPosition)
end)

asset.export(FranciscoPosition)
asset.export(CalibanPosition)
asset.export(StephanoPosition)
asset.export(TrinculoPosition)
asset.export(SycoraxPosition)
asset.export(ProsperoPosition)
asset.export(SetebosPosition)
asset.export(FerdinandPosition)
asset.export(S2023U1Position)



asset.meta = {
  Name = "Uranus Irregular Retrograde Moons Positions",
  Description = [[Asset containing positions for Uranus' irregular retrograde moons.]],
