local transforms = asset.require("scene/solarsystem/planets/uranus/transforms")
local kernel = asset.require("scene/solarsystem/planets/uranus/kernels184")
local coreKernels = asset.require("spice/core")



local FranciscoPosition = {
  Identifier = "FranciscoPosition",
  Parent = transforms.UranusBarycenter.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernel.ID.Francisco,
      Observer = coreKernels.ID.UranusBarycenter
    }
  },
  GUI = {
    Name = "Francisco Position",
    Path = "/Solar System/Planets/Uranus/Minor Moons/Irregular Retrograde Moons/Francisco",
    Focusable = false,
    Hidden = true
  }
}

