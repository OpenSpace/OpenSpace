local transforms = asset.require("./transforms")



local MirandaLabel = {
  Identifier = "MirandaLabel",
  Parent = transforms.MirandaPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Text = "Miranda",
    FontSize = 70.0,
    Size = 7.4,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 1, 250.0 },
    FadeWidths = { 1, 250.0 }
  },
  Tag = { "solarsystem_labels", "moon_labels", "major_moon_labels" },
  GUI = {
    Name = "Miranda Label",
    Path = "/Solar System/Planets/Uranus/Major Moons/Miranda",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(MirandaLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(MirandaLabel)
end)

asset.export(MirandaLabel)



asset.meta = {
  Name = "Miranda Label",
  Description = [[Miranda Label]],
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
