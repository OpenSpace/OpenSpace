local transforms = asset.require("../transforms")
local kernels = asset.require("../kernels")
local coreKernels = asset.require("spice/core")



local MirandaPosition = {
  Identifier = "MirandaPosition",
  Parent = transforms.UranusBarycenter.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.Miranda,
      Observer = coreKernels.ID.UranusBarycenter
    }
  },
  GUI = {
    Name = "Miranda Position",
    Path = "/Solar System/Planets/Uranus/Major Moons/Miranda",
    Focusable = false,
    Hidden = true
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(MirandaPosition)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(MirandaPosition)
end)

asset.export(MirandaPosition)



asset.meta = {
  Name = "Miranda Position",
  Description = [[Position for Miranda]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
