local transforms = asset.require("./transforms")
local coreKernels = asset.require("spice/core")



local OberonLabel = {
  Identifier = "OberonLabel",
  Parent = transforms.OberonPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Text = "Oberon",
    FontSize = 70.0,
    Size = 7.4,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 1, 250.0 },
    FadeWidths = { 1, 250.0 }
  },
  Tag = { "solarsystem_labels", "moon_labels", "major_moon_labels" },
  GUI = {
    Name = "Oberon Label",
    Path = "/Solar System/Planets/Uranus/Major Moons/Oberon",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(OberonLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(OberonLabel)
end)

asset.export(OberonLabel)



asset.meta = {
  Name = "Oberon Label",
  Description = [[Label for Oberon]],
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
