local transforms = asset.require("./transforms")
local coreKernels = asset.require("spice/core")



local TitaniaLabel = {
  Identifier = "TitaniaLabel",
  Parent = transforms.TitaniaPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Titania",
    FontSize = 70.0,
    Size = 7.4,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 1, 250.0 },
    FadeWidths = { 1, 250.0 }
  },
  Tag = { "solarsystem_labels", "moon_labels", "major_moon_labels" },
  GUI = {
    Name = "Titania Label",
    Path = "/Solar System/Planets/Uranus/Major Moons/Titania",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(TitaniaLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TitaniaLabel)
end)

asset.export(TitaniaLabel)



asset.meta = {
  Name = "Titania Label",
  Description = [[Position for Label]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
