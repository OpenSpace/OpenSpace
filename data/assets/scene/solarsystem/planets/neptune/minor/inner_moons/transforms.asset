asset.onInitialize(function()
  openspace.addSceneGraphNode(NaiadPosition)
  openspace.addSceneGraphNode(ThalassaPosition)
  openspace.addSceneGraphNode(DespinaPosition)
  openspace.addSceneGraphNode(GalateaPosition)
  openspace.addSceneGraphNode(LarissaPosition)
  openspace.addSceneGraphNode(HippocampPosition)
  openspace.addSceneGraphNode(ProteusPosition)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(ProteusPosition)
  openspace.removeSceneGraphNode(HippocampPosition)
  openspace.removeSceneGraphNode(LarissaPosition)
  openspace.removeSceneGraphNode(GalateaPosition)
  openspace.removeSceneGraphNode(DespinaPosition)
  openspace.removeSceneGraphNode(ThalassaPosition)
  openspace.removeSceneGraphNode(NaiadPosition)
end)

asset.export(NaiadPosition)
asset.export(ThalassaPosition)
asset.export(DespinaPosition)
asset.export(GalateaPosition)
asset.export(LarissaPosition)
asset.export(HippocampPosition)
asset.export(ProteusPosition)



asset.meta = {
  Name = "Neptune Inner Moons Globe",
  Description = [[Asset containing globes for Neptune' inner prograde moons.]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
