local HalimedeTrail = {
  Identifier = "HalimedeTrail",
  Parent = transforms.NeptuneBarycenter.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.Halimede,
      Observer = coreKernels.ID.NeptuneBarycenter
    },
    Color = { 0.2, 0.5, 0.75 },
    Period = 1879.08,
    Resolution = 1000
  },
  Tag = {
    "moonTrail_solarSystem",
    "moonTrail_giants",
    "moonTrail_neptune",
    "moonTrail_minor",
    "moonTrail_minor_neptune"
  },
  GUI = {
    Name = "Halimede Trail",
    Path = "/Solar System/Planets/Neptune/Minor Moons/Irregular Prograde Moons/Halimede",
    Focusable = false
