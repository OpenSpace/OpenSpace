local transforms = asset.require("scene/solarsystem/planets/neptune/transforms")
local kernels = asset.require("scene/solarsystem/planets/neptune/kernels104")
local coreKernels = asset.require("spice/core")



local HalimedePosition = {
  Identifier = "HalimedePosition",
  Parent = transforms.NeptuneBarycenter.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.Halimede,
      Observer = coreKernels.ID.NeptuneBarycenter
    }
  },
  GUI = {
    Name = "Halimede Position",
    Path = "/Solar System/Planets/Neptune/Minor Moons/Irregular Prograde Moons/Halimede",
    Focusable = false,
    Hidden = true
  }
}

