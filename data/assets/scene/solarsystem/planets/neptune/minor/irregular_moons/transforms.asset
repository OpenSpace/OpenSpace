asset.onInitialize(function()
  openspace.addSceneGraphNode(HalimedePosition)
  openspace.addSceneGraphNode(PsamathePosition)
  openspace.addSceneGraphNode(SaoPosition)
  openspace.addSceneGraphNode(LaomedeiaPosition)
  openspace.addSceneGraphNode(NesoPosition)
  openspace.addSceneGraphNode(S2002N5Position)
  openspace.addSceneGraphNode(S2021N1Position)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(S2021N1Position)
  openspace.removeSceneGraphNode(S2002N5Position)
  openspace.removeSceneGraphNode(NesoPosition)
  openspace.removeSceneGraphNode(LaomedeiaPosition)
  openspace.removeSceneGraphNode(SaoPosition)
  openspace.removeSceneGraphNode(PsamathePosition)
  openspace.removeSceneGraphNode(HalimedePosition)
end)

asset.export(HalimedePosition)
asset.export(PsamathePosition)
asset.export(SaoPosition)
asset.export(LaomedeiaPosition)
asset.export(NesoPosition)
asset.export(S2002N5Position)
asset.export(S2021N1Position)



asset.meta = {
  Name = "Neptune Irregular Prograde and Retrograde Moons Globes",
