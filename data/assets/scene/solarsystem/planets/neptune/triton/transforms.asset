local transforms = asset.require("../transforms")
local kernels = asset.require("./kernels")
local coreKernels = asset.require("spice/core")



local TritonPosition = {
  Identifier = "TritonPosition",
  Parent = transforms.NeptuneBarycenter.Identifier,
  Transform = {
    Translation = {
      Type = "SpiceTranslation",
      Target = kernels.ID.Triton,
      Observer = coreKernels.ID.NeptuneBarycenter
    },
    Rotation = {
      Type = "SpiceRotation",
      SourceFrame = kernels.Frame.Triton,
      DestinationFrame = coreKernels.Frame.Galactic
    }
  },
  GUI = {
    Name = "Triton Position",
    Path = "/Solar System/Planets/Neptune/Major Moons/Triton",
    Focusable = false,
    Hidden = true
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(TritonPosition)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TritonPosition)
end)

asset.export(TritonPosition)



asset.meta = {
  Name = "Triton Position",
  Description = [[Position for Neptune's moon Triton]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
