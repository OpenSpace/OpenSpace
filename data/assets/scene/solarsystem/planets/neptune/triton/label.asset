local transforms = asset.require("./transforms")
local coreKernels = asset.require("spice/core")



local TritonLabel = {
  Identifier = "TritonLabel",
  Parent = transforms.TritonPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Triton",
    FontSize = 50.0,
    Size = 7.0,
    MinMaxSize = { 1, 25 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "Gm",
    FadeDistances = { 1, 15.0 },
    FadeWidths = { 1, 15.0 }
  },
  Tag = { "solarsystem_labels", "moon_labels", "major_moon_labels" },
  GUI = {
    Name = "Triton Label",
    Path = "/Solar System/Planets/Neptune/Major Moons/Triton",
    Focusable = false,
    Description = "Label for Neptune's moon Triton"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(TritonLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(TritonLabel)
end)

asset.export(TritonLabel)



asset.meta = {
  Name = "Triton Label",
  Description = [[Label for Neptune's moon Triton]],
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
