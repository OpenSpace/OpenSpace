local transforms = asset.require("./transforms")



local VenusLabel = {
  Identifier = "VenusLabel",
  Parent = transforms.VenusBarycenter.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "Venus",
    FontSize = 70.0,
    Size = 8.5,
    MinMaxSize = { 1, 40 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "au",
    FadeDistances = { 0.75, 25.0 },
    FadeWidths = { 1.0, 35.0 }
  },
  Tag = { "solarsystem_labels" },
  GUI = {
    Name = "Venus Label",
    Path = "/Solar System/Planets/Venus",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(VenusLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(VenusLabel)
end)

asset.export(VenusLabel)



asset.meta = {
  Name = "Venus Label",
  Description = "Label for Venus",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
