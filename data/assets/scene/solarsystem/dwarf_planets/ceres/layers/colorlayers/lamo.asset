local ceresAsset = asset.require("scene/solarsystem/dwarf_planets/ceres/globe")



local Layer = {
  Identifier = "LAMO_Sweden",
  Name = "LAMO [Sweden]",
  Enabled = asset.enabled,
  ZIndex = 10,
  FilePath = asset.resource("lamo.wms")
}


asset.onInitialize(function()
  openspace.globebrowsing.addLayer(ceresAsset.Ceres.Identifier, "ColorLayers", Layer)
end)

asset.onDeinitialize(function()
  openspace.globebrowsing.deleteLayer(ceresAsset.Ceres.Identifier, "ColorLayers", Layer)
end)

asset.export("layer", Layer)



asset.meta = {
  Name = "LAMO [Sweden]",
  Description = [[]],
  Author = "",
  URL = "",
  License = ""
}
