local transforms = asset.require("./transforms")



local Styx = {
  Identifier = "Styx",
  Parent = transforms.StyxPosition.Identifier,
  Renderable = {
    Type = "RenderableGlobe",
    Radii = { 45000, 45000, 45000 }
  },
  Tag = {
    "moon_solarSystem",
    "moon_dwarf",
    "moon_pluto",
    "moon_minor",
    "moon_minor_pluto"
  },
  GUI = {
    Path = "/Solar System/Dwarf Planets/Pluto/Moons/Styx"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(Styx)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(Styx)
end)

asset.export(Styx)



asset.meta = {
  Name = "Styx Globe",
  Description = "Globe for Pluto's moon Styx",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
