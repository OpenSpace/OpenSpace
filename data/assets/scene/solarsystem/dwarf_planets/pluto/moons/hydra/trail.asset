local plutoAsset = asset.require("scene/solarsystem/dwarf_planets/pluto/transforms")
local plutoKernels = asset.require("scene/solarsystem/dwarf_planets/pluto/kernels")



local HydraTrail = {
  Identifier = "HydraTrail",
  Parent = plutoAsset.PlutoBarycenter.Identifier,
  Renderable = {
    Type = "RenderableTrailOrbit",
    Translation = {
      Type = "SpiceTranslation",
      Target = plutoKernels.ID.Hydra,
      Observer = plutoKernels.ID.PlutoBarycenter
    },
    Color = { 0.00, 0.62, 1.00 },
    Period = 38.20177,
    Resolution = 1000
  },
  Tag = {
    "moonTrail_solarSystem",
    "moonTrail_dwarf",
    "moonTrail_pluto",
    "moonTrail_minor",
    "moonTrail_minor_pluto"
  },
  GUI = {
    Name = "Hydra Trail",
    Path = "/Solar System/Dwarf Planets/Pluto/Moons/Hydra",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(HydraTrail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(HydraTrail)
end)

asset.export(HydraTrail)



asset.meta = {
  Name = "Hydra Trail",
  Description = "Trail for Pluto's moon Hydra",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
