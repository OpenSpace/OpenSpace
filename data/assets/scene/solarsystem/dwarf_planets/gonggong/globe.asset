local transforms = asset.require("./transforms")



local Gonggong = {
  Identifier = "Gonggong",
  Parent = transforms.GonggongPosition.Identifier,
  Transform = {
    Rotation = {
      Type = "ConstantRotation",
      RotationAxis = { 0.0, 0.0, 1.0 },
      RotationRate = 1.0 / (22.4 * 60.0 * 60.0)
    }
  },
  Renderable = {
    Type = "RenderableGlobe",
    Radii = { 615000, 615000, 615000 }
  },
  GUI = {
    Name = "Gonggong",
    Path = "/Solar System/Dwarf Planets/Gonggong"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(Gonggong)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(Gonggong)
end)

asset.export(Gonggong)



asset.meta = {
  Name = "Gonggong Globe",
  Description = [[Globe of Gonggong]],
  Author = "OpenSpace Team",
  URL = "https://www.openspaceproject.com",
  License = "MIT"
}
