local transforms = asset.require("./transforms")



local AtlasLabel = {
  Identifier = "3I_AtlasLabel",
  Parent = transforms.AtlasPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Text = "3I/ATLAS",
    FontSize = 70.0,
    Size = 8.50,
    MinMaxSize = { 1, 50 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "au",
    FadeDistances = { 1.5, 50.0 },
    FadeWidths = { 1.0, 40.0 }
  },
  Tag = { "solarsystem_labels" },
  GUI = {
    Name = "3I/ATLAS Label",
    Path = "/Solar System/Interstellar/ATLAS",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(AtlasLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(AtlasLabel)
end)

asset.export(AtlasLabel)



asset.meta = {
  Name = "3I/ATLAS Label",
  Description = [[This asset contains the label of 3I/ATLAS from 2020 JUL 01 00:00:00 to
    2030 JUL 01 00:00:00. Data from JPL Horizons.]],
  Author = "OpenSpace Team",
  URL = "https://ssd.jpl.nasa.gov/horizons.cgi",
  License = "NASA"
}
