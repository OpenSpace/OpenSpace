local transforms = asset.require("./transforms")



local OumuamuaLabel = {
  Identifier = "1I_OumuamuaLabel",
  Parent = transforms.OumuamuaPosition.Identifier,
  Renderable = {
    Type = "RenderableLabel",
    Enabled = asset.enabled,
    Text = "1I/'Oumuamua",
    FontSize = 70.0,
    Size = 8.50,
    MinMaxSize = { 1, 50 },
    OrientationOption = "Camera View Direction",
    BlendMode = "Additive",
    EnableFading = true,
    FadeUnit = "au",
    FadeDistances = { 1.5, 50.0 },
    FadeWidths = { 1.0, 40.0 }
  },
  Tag = { "solarsystem_labels" },
  GUI = {
    Name = "1I/'Oumuamua Label",
    Path = "/Solar System/Interstellar/'Oumuamua",
    Focusable = false
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(OumuamuaLabel)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(OumuamuaLabel)
end)

asset.export(OumuamuaLabel)



asset.meta = {
  Name = "1I/'Oumuamua Label",
  Description = [[This asset contains the label of 1I/'Oumuamua from 2014 JAN 01 00:00:00
    to 2050 JAN 01 00:00:00. Data from JPL Horizons]],
  Author = "OpenSpace Team",
  URL = "https://ssd.jpl.nasa.gov/horizons.cgi",
  License = "NASA"
}
