local data_folder = asset.resource({
  Name = "DESI Quasars Data Files",
  Type = "HttpSynchronization",
  Identifier = "digitaluniverse_desi_quasars_data",
  Version = 1
})

local texture_folder = asset.resource({
  Name = "Point Textures",
  Type = "HttpSynchronization",
  Identifier = "digitaluniverse_point_textures",
  Version = 1
})


local Object = {
  Identifier = "DESI_Quasars",
  Renderable = {
    Type = "RenderablePointCloud",
    File = data_folder .. "desi_quasars.csv",
    Unit = "Mpc",
    Coloring = {
      FixedColor = { 0.85, 0.35, 0.18 }
    },
    Opacity = 0.95,
    Texture = { File = texture_folder .. "point3A.png" },
    SizeSettings = {
      ScaleExponent = 23.5,
      MaxSize = 0.3,
      EnableMaxSizeControl = true
    },
    Fading = {
      FadeInDistances = { 1000.0, 10000.0 }
    }
  },
  GUI = {
    Name = "DESI Quasars",
    Path = "/Universe/Deep Sky Surveys",
    Description = [[The DESI (Dark Energy Spectroscopic Instrument) catalog of quasars.
      Census: 2,182,309 quasars.]]
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(Object)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(Object)
end)

asset.export(Object)



asset.meta = {
  Name = "DESI Quasars",
  Description = Object.GUI.Description,
  Author = "Cade Mohrhardt, Brian Abbott (AMNH)",
  URL = "https://www.amnh.org/research/hayden-planetarium/digital-universe",
  License = "AMNH Digital Universe"
}
