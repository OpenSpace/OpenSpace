-- Basic
-- This example adds a dashboard item that shows the status of the Astrocast.

local Item = {
  Identifier = "DashboardItemAstrocast_Example",
  Type = "DashboardItemAstrocast"
}


asset.onInitialize(function()
  openspace.dashboard.addDashboardItem(Item)
end)

asset.onDeinitialize(function()
  openspace.dashboard.removeDashboardItem(Item)
end)
