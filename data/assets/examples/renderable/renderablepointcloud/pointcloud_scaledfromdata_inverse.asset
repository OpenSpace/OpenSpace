-- Point Size from Data - Inverted
-- This example creates a point cloud where the size of the points is computed based on
-- a column in the dataset. In this example, the size mapping is inverted, so that higher
-- values in the column result in smaller points and vice versa.

local Node = {
  Identifier = "RenderablePointCloud_Example_ScaledFromData_Inverted",
  Renderable = {
    Type = "RenderablePointCloud",
    File = asset.resource("data/dummydata.csv"),
    Coloring = {
      FixedColor = { 0.5, 0.5, 0.0 }
    },
    SizeSettings = {
      SizeMapping = {
        -- The options for the columns that the points can be scaled by. The first
        -- alternative in the list is chosen per default
        ParameterOptions = { "a", "b" },
        -- Specify which option we want to use for size mapping at start up. Here we
        -- use the last of the provided options rather than the first one, which is
        -- otherwise used by default
        Parameter = "b",
        -- Invert the size mapping, so that higher values in the column result in
        -- smaller points and vice versa
        InvertScale = true
      }
    }
  },
  GUI = {
    Name = "RenderablePointCloud - Size from Data (Inverted)",
    Path = "/Examples"
  }
}


asset.onInitialize(function()
  openspace.addSceneGraphNode(Node)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(Node)
end)
