local action = asset.require("../actions/fade_glyphs")

-- Events that handle the "close up" view of exoplanet systems.
-- The glyph renderable are faded in and faded out when approaching / leaving

asset.onInitialize(function()
  openspace.event.registerEventAction(
    "CameraFocusTransition",
    action.ShowGlyphs,
    { Transition = "Exiting" }
  )
  openspace.event.registerEventAction(
    "CameraFocusTransition",
    action.HideGlyphs,
    { Transition = "Approaching" }
  )
end)


asset.onDeinitialize(function()
  openspace.event.unregisterEventAction(
    "CameraFocusTransition",
    action.ShowGlyphs,
    { Transition = "Exiting" }
  )
  openspace.event.unregisterEventAction(
    "CameraFocusTransition",
    action.HideGlyphs,
    { Transition = "Approaching" }
  )
end)
