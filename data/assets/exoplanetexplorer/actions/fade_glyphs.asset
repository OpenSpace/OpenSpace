local identifier = "ExoplanetDataPoints"

local HideGlyphs = {
  Identifier = "os.hide_exo_glyphs",
  Name = "Hide ExoExplorer Renderable",
  Command = [[openspace.fadeOut("Scene.]] .. identifier .. [[.Renderable")]],
  Documentation = [[]],
  GuiPath = "/ExoplanetExplorer",
  IsLocal = false
}
asset.export("HideGlyphs", HideGlyphs.Identifier)

local ShowGlyphs = {
  Identifier = "os.show_exo_glyphs",
  Name = "Show ExoExplorer Renderable",
  Command = [[openspace.fadeIn("Scene.]] .. identifier .. [[.Renderable")]],
  Documentation = [[]],
  GuiPath = "/ExoplanetExplorer",
  IsLocal = false
}
asset.export("ShowGlyphs", ShowGlyphs.Identifier)

local ToggleGlyphs = {
  Identifier = "os.toggle_exo_glyphs",
  Name = "Toggle ExoExplorer Renderable",
  Command = [[openspace.toggleFade("Scene.]] .. identifier .. [[.Renderable")]],
  Documentation = [[]],
  GuiPath = "/ExoplanetExplorer",
  IsLocal = false
}
asset.export("ToggleGlyphs", ToggleGlyphs.Identifier)

asset.onInitialize(function()
  openspace.action.registerAction(ShowGlyphs)
  openspace.action.registerAction(HideGlyphs)
  openspace.action.registerAction(ToggleGlyphs)

  openspace.bindKey("G", ToggleGlyphs)
end)

asset.onDeinitialize(function()
  openspace.clearKey("G")

  openspace.action.removeAction(ToggleGlyphs)
  openspace.action.removeAction(HideGlyphs)
  openspace.action.removeAction(ShowGlyphs)
end)


asset.meta = {
  Name = "Actions - Show/Hide Exoplanet Explorer Renderable",
  Author = "OpenSpace Team",
  URL = "http://openspaceproject.com",
  License = "MIT license"
}
