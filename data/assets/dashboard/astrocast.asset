local Item = {
  Type = "DashboardItemAstrocast",
  Identifier = "Astrocast",
  GuiName = "Astrocast"
}


asset.onInitialize(function()
  openspace.dashboard.addDashboardItem(Item)
end)

asset.onDeinitialize(function()
  openspace.dashboard.removeDashboardItem(Item)
end)

asset.export(Item)



asset.meta = {
  Name = "Dashboard - AstroCast",
  Description = "This asset provides an Astrocast dashboard item",
  Author = "OpenSpace Team",
  URL = "https://openspaceproject.com",
  License = "MIT license"
}
